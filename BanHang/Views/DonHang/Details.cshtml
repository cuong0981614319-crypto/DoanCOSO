@model BanHang.Models.DonHang

@{
  
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Chi tiết đơn hàng #@Model.MaDonHang</h2>
        <a asp-action="MyOrders" class="btn btn-secondary">Quay lại</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><strong>Họ tên:</strong> @Model.HoTen</p>
            <p><strong>Số điện thoại:</strong> @Model.SoDienThoai</p>
            <p><strong>Địa chỉ:</strong> @Model.DiaChi</p>
            <p><strong>Ngày đặt:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@Model.TongTien.ToString("N0") VNĐ</span></p>
            <p><strong>Trạng thái:</strong> @Model.TrangThai</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="mb-3">Sản phẩm trong đơn</h5>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Ảnh</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
                        {
                            foreach (var item in Model.ChiTietDonHangs)
                            {
                                <tr>
                                    <td>@item.SanPham?.TenSanPham</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.SanPham?.HinhAnh))
                                        {
                                            <img src="@item.SanPham.HinhAnh"
                                                 alt="@item.SanPham.TenSanPham"
                                                 style="width: 70px; height: 70px; object-fit: contain;" />
                                        }
                                    </td>
                                    <td>@item.SoLuong</td>
                                    <td>@item.DonGia.ToString("N0") VNĐ</td>
                                    <td class="text-danger fw-bold">@((item.SoLuong * item.DonGia).ToString("N0")) VNĐ</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    Không có chi tiết đơn hàng.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>