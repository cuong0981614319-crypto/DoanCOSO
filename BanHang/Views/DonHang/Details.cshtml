@model BanHang.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.MaDonHang;
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase">Chi tiết đơn hàng #@Model.MaDonHang</h2>
        <a asp-action="MyOrders" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-geo-alt"></i> Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6 mb-2">
                            <p class="mb-1 text-muted">Họ tên người nhận</p>
                            <p class="fw-bold">@Model.HoTen</p>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <p class="mb-1 text-muted">Số điện thoại</p>
                            <p class="fw-bold">@Model.SoDienThoai</p>
                        </div>
                        <div class="col-12 mb-2">
                            <p class="mb-1 text-muted">Địa chỉ nhận hàng</p>
                            <p class="fw-bold">@Model.DiaChi</p>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <p class="mb-1 text-muted">Ghi Chú</p>
                            <p class="fw-bold">@Model.GhiChu</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 text-muted">Ngày đặt đơn</p>
                            <p class="fw-bold">@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-sm-6">
                            <p class="mb-1 text-muted">Trạng thái hiện tại</p>
                            <span class="badge bg-info text-dark p-2">@Model.TrangThai</span>
                        </div>
                        <div class="col-sm-12">
                            <p class="mb-1 text-muted">Ghi Chú</p>
                            <p class="fw-bold">@Model.GhiChu</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-box-seam"></i> Sản phẩm trong đơn</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th>Ảnh</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
                                {
                                    foreach (var item in Model.ChiTietDonHangs)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold">@item.SanPham?.TenSanPham</div>
                                                <small class="text-muted">Mã SP: @item.MaSanPham</small>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.SanPham?.HinhAnh))
                                                {
                                                    <img src="@item.SanPham.HinhAnh" class="rounded border"
                                                         style="width: 60px; height: 60px; object-fit: cover;" />
                                                }
                                            </td>
                                            <td class="text-center">@item.SoLuong</td>

                                            @* --- ĐÂY LÀ CHỖ THAY ĐỔI --- *@
                                            <td class="text-end">
                                                @if (item.SanPham?.PhanTramGiam > 0)
                                                {
                                                    <div class="text-danger fw-bold">@item.SanPham.GiaKhuyenMai.ToString("N0") đ</div>
                                                    <div class="text-muted text-decoration-line-through" style="font-size: 0.8rem; margin-top: -2px;">
                                                        @item.SanPham.Gia.ToString("N0") đ
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="fw-bold">@item.DonGia.ToString("N0") đ</div>
                                                }
                                            </td>
                                            @* --------------------------- *@

                                            <td class="text-end pe-4 text-danger fw-bold">
                                                @((item.SoLuong * item.DonGia).ToString("N0")) đ
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="4" class="text-end fw-bold py-3">TỔNG CỘNG:</td>
                                    <td class="text-end pe-4 text-danger fw-bold fs-5 py-3">
                                        @Model.TongTien.ToString("N0") VNĐ
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-success"><i class="bi bi-clock-history"></i> Lịch sử đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        @if (Model.LichSuDonHangs != null && Model.LichSuDonHangs.Any())
                        {
                            @foreach (var ls in Model.LichSuDonHangs.OrderByDescending(x => x.NgayTao))
                            {
                                <div class="timeline-item pb-4 position-relative ps-4 border-start border-2 border-success">
                                    <span class="position-absolute start-0 translate-middle-x bg-success rounded-circle"
                                          style="width: 12px; height: 12px; margin-left: -1px; margin-top: 5px;"></span>
                                    <div class="fw-bold text-dark">@ls.TrangThaiMoi</div>
                                    <div class="text-muted small">@ls.GhiChu</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        <i class="bi bi-calendar3"></i> @ls.NgayTao.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-info-circle text-muted fs-2"></i>
                                <p class="text-muted small mt-2">Đang chờ xác nhận từ hệ thống...</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Style cho Timeline */
    .timeline {
        padding-left: 10px;
    }

    .timeline-item:last-child {
        border-start: none !important; /* Dòng cuối không có kẻ sọc */
        padding-bottom: 0 !important;
    }

    .card {
        border-radius: 12px;
    }

    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>