@model IEnumerable<BanHang.Models.DonHang>

<div class="container mt-4 my-orders-page">
    <h2 class="fw-bold mb-4">Đơn hàng của tôi</h2>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ảnh</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>#@item.MaDonHang</strong></td>
                                    <td>
                                        @{
                                            var firstDetail = item.ChiTietDonHangs?.FirstOrDefault();
                                        }

                                        @if (firstDetail != null && !string.IsNullOrEmpty(firstDetail.SanPham.HinhAnh))
                                        {
                                            <img src="@firstDetail.SanPham.HinhAnh"
                                                 alt="Product"
                                                 style="width:70px; height:70px; object-fit:contain;"
                                                 class="border rounded p-1" />
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size: 12px;">Không có ảnh</span>
                                        }
                                    </td>
                                    <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>

                                    <td class="text-danger fw-bold">
                                        @item.TongTien.ToString("N0") VNĐ
                                    </td>

                                    <td>
                                        @if (item.DaThanhToan)
                                        {
                                            <span class="badge bg-success">Đã thanh toán</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                                        }
                                    </td>

                                    <td>
                                        @switch (item.TrangThai)
                                        {
                                            case "Chờ xác nhận":
                                                <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                                break;
                                            case "Chờ thanh toán":

                                                <span class="badge bg-secondary">Chờ thanh toán</span>
                                                break;
                                            case "Đã xác nhận":

                                                <span class="badge bg-primary">Đã xác nhận</span>
                                                break;
                                            case "Đang giao":

                                                <span class="badge bg-info text-dark">Đang giao</span>
                                                break;
                                            case "Hoàn thành":

                                                <span class="badge bg-success">Hoàn thành</span>
                                                break;
                                            case "Đã hủy":

                                                <span class="badge bg-danger">Đã hủy</span>
                                                break;
                                            default:

                                                <span class="badge bg-secondary">@item.TrangThai</span>
                                                break;
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <!-- CHI TIẾT -->
                                            <a asp-action="Details"
                                               asp-route-id="@item.MaDonHang"
                                               class="btn btn-sm btn-outline-primary">
                                                Chi tiết
                                            </a>

                                            <!-- NÚT ĐÁNH GIÁ (Chỉ hiện khi Hoàn thành) -->
                                            @if (item.TrangThai == "Hoàn thành")
                                            {
                                                <a asp-action="Danhgia"
                                                   asp-controller="Product"
                                                   asp-route-id="@item.ChiTietDonHangs.FirstOrDefault()?.MaSanPham"
                                                   class="btn btn-sm btn-warning">
                                                    <i class="fas fa-star me-1"></i>Đánh giá
                                                </a>
                                            }

                                            <!-- HỦY -->
                                            @if ((item.TrangThai == "Chờ xác nhận" || item.TrangThai == "Chờ thanh toán") && !item.DaThanhToan)
                                            {
                                                <form asp-controller="DonHang"
                                                      asp-action="CancelOrder"
                                                      asp-route-id="@item.MaDonHang"
                                                      method="post"
                                                      class="d-inline"
                                                      onsubmit="return confirm('Bạn có chắc muốn hủy đơn này không?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        Hủy
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Bạn chưa có đơn hàng nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>