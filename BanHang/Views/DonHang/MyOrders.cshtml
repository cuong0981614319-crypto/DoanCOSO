@model IEnumerable<BanHang.Models.DonHang>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container mt-4">
    <h2 class="mb-4">Đơn hàng của tôi</h2>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.MaDonHang</td>
                                    <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-danger fw-bold">@item.TongTien.ToString("N0") VNĐ</td>
                                    <td>
                                        @if (item.TrangThai == "Chờ xác nhận")
                                        {
                                            <span class="badge bg-warning text-dark">@item.TrangThai</span>
                                        }
                                        else if (item.TrangThai == "Đã xác nhận")
                                        {
                                            <span class="badge bg-primary">@item.TrangThai</span>
                                        }
                                        else if (item.TrangThai == "Đang giao")
                                        {
                                            <span class="badge bg-info text-dark">@item.TrangThai</span>
                                        }
                                        else if (item.TrangThai == "Hoàn thành")
                                        {
                                            <span class="badge bg-success">@item.TrangThai</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">@item.TrangThai</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details"
                                               asp-route-id="@item.MaDonHang"
                                               class="btn btn-sm btn-outline-primary">
                                            Xem
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    Bạn chưa có đơn hàng nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>