@model BanHang.Models.SanPham
@using BanHang.Models

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BanHang.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
   
    var sanPhamCungLoai = ViewBag.SanPhamCungLoai as List<SanPham> ?? new List<SanPham>();
    var dsAnh = Model.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any()
        ? Model.HinhAnhSanPhams
        : new List<HinhAnhSanPham>();

    int quantity = ViewBag.Quantity != null ? (int)ViewBag.Quantity : 1;
    var mainImage = string.IsNullOrEmpty(Model.HinhAnh)
        ? "https://via.placeholder.com/500x400"
        : Model.HinhAnh;
} 

<link rel="stylesheet" href="~/css/productUser/Details.css" asp-append-version="true" />

<div class="container mt-4 product-detail-page">
    <div class="row g-4">
        <div class="col-md-5">
            <div class="border rounded p-3 bg-white shadow-sm main-image-box">
                <img id="mainProductImage"
                     src="@mainImage"
                     alt="@Model.TenSanPham"
                     class="img-fluid w-100"
                     style="height: 400px; object-fit: contain;" />
            </div>

            @if (dsAnh.Any())
            {
                <div class="row g-2 mt-3 thumbnail-list">
                    @foreach (var img in dsAnh)
                    {
                        <div class="col-3">
                            <img src="@img.DuongDanAnh"
                                 alt="@Model.TenSanPham"
                                 class="img-fluid border rounded product-thumb @(mainImage == img.DuongDanAnh ? "active-thumb" : "")"
                                 style="height: 90px; width: 100%; object-fit: contain; cursor: pointer;" />
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold mb-3">@Model.TenSanPham</h2>
            <div class="d-flex align-items-center gap-1 mt-1">
                <span class="text-warning">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(Model.AvgRating))
                        {
                            <span>★</span>
                        }
                        else
                        {
                            <span>☆</span>
                        }
                    }
                </span>
                <small class="text-muted">
                    (@Model.TotalReviews)
                </small>
            </div>
            <p class="mb-2">
                <strong>Danh mục:</strong> @(Model.DanhMuc?.TenDanhMuc ?? "Chưa có")
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.MauSac))
            {
                <p class="mb-2">
                    <strong>Màu sắc:</strong> @Model.MauSac
                </p>
            }

            <div class="price-quantity-inline mb-3">
               
                <div class="price-container d-flex align-items-baseline mb-3" style="gap: 8px;">
                    @if (Model.PhanTramGiam > 0)
                    {
                      
                        <div class="badge-discount border px-1 text-danger fw-bold"
                             style="font-size: 0.8rem; background-color: #fff5f5; border-color: #feb2b2 !important;">
                            -@Model.PhanTramGiam%
                        </div>

                  
                        <div class="current-price text-danger fw-bold fs-4">
                            @Model.GiaKhuyenMai.ToString("N0") VNĐ
                        </div>

                     
                        <div class="original-price text-muted text-decoration-line-through" style="font-size: 0.9rem;">
                            @Model.Gia.ToString("N0") VNĐ
                        </div>
                       
                    }
                    else
                    {
                        <div class="current-price text-danger fw-bold fs-4">
                            @Model.Gia.ToString("N0") VNĐ
                        </div>
                
                    }
                </div>
            </div>

            <div class="product-specifications mb-4">
                @if (!string.IsNullOrWhiteSpace(Model?.kichthuc))
                {
                    <p class="mb-2">
                        <i class="bi bi-aspect-ratio me-2"></i>
                        <strong>Kích thước:</strong> @Model?.kichthuc
                    </p>
                }

                @if (!string.IsNullOrWhiteSpace(Model?.chatlieu))
                {
                    <p class="mb-2">
                        <i class="bi bi-box-seam me-2"></i>
                        <strong>Chất liệu:</strong> @Model?.chatlieu
                    </p>
                }
            </div>

            <div class="mb-4">
                <strong>Mô tả:</strong>
                <div class="mt-2 text-muted">
                    @if (Model != null && !string.IsNullOrWhiteSpace(Model.MoTa))
                    {
                        @Model.MoTa
                    }
                    else
                    {
                        <span>Chưa có mô tả sản phẩm.</span>
                    }
                </div>
            </div>
            <div class="mb-3">
                <span class="btn btn-sm btn-outline-success disabled">
                    Đã bán @Model.DaBan
                </span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="Admin"
                       asp-controller="Product"
                       asp-action="Edit"
                       asp-route-id="@Model.MaSanPham"
                       class="btn btn-warning">
                        Sửa sản phẩm
                    </a>
                }
                else if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <button type="button"
                                id="btnAddToCart"
                                data-id="@Model.MaSanPham"
                                class="btn btn-dark">
                            Thêm vào giỏ hàng
                        </button>
                    </div>
                }
                else
                {
                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="btn btn-outline-dark">
                        Thêm vào giỏ hàng
                    </a>
                }

                @if (!User.IsInRole("Admin") && User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <button type="button"
                            id="btnBuyNow"
                            data-id="@Model.MaSanPham"
                            class="btn btn-buy-now">
                        Mua ngay
                    </button>
                }
                else if (!User.IsInRole("Admin"))
                {
                    <a asp-area="Identity"
                           asp-page="/Account/Login"
                           asp-route-returnUrl="@Context.Request.Path"
                           class="btn btn-buy-now">
                        Mua ngay
                    </a>
                }
            </div>
        </div>
    </div>
    <hr />
    <h3>Đánh giá sản phẩm</h3>

    <div class="d-flex gap-3 mb-3">

        <!-- Lọc sao -->
        <select id="filterStar" class="form-select" onchange="applyFilter()">
            <option value="" selected="@(ViewBag.CurrentStar == null)">Tất cả sao</option>
            <option value="5" selected="@(ViewBag.CurrentStar == 5)">5★</option>
            <option value="4" selected="@(ViewBag.CurrentStar == 4)">4★</option>
            <option value="3" selected="@(ViewBag.CurrentStar == 3)">3★</option>
            <option value="2" selected="@(ViewBag.CurrentStar == 2)">2★</option>
            <option value="1" selected="@(ViewBag.CurrentStar == 1)">1★</option>
        </select>

        <!-- Lọc ảnh -->
        <select id="filterImage" class="form-select" onchange="applyFilter()">
            <option value="" selected="@(ViewBag.HasImage == null)">Tất cả</option>
            <option value="true" selected="@(ViewBag.HasImage == true)">Có hình ảnh</option>
        </select>

    </div>
    <!-- Hiển thị danh sách đánh giá -->
    <div class="reviews">

        @if (Model.DanhGias != null && Model.DanhGias.Any())
        {
            @foreach (var review in Model.DanhGias)
            {
                <div class="review-item border-bottom mb-3"
                     data-star="@review.Diem"
                     data-has-image="@(review.Images != null && review.Images.Any() ? "true" : "false")">
                    <strong>@review.TenNguoiDung</strong>
                    <span class="text-warning">@(new string('★', review.Diem))</span>
                    <p>@review.NoiDung</p>

                    @if (review.Images != null && review.Images.Any())
                    {
                        <div class="review-images mt-2">
                            @foreach (var img in review.Images)
                            {
                                <img src="@img.ImageUrl"
                                     class="review-img"
                                     onclick="openImageModal('@img.ImageUrl')" />
                            }
                        </div>
                    }
                    <small class="text-muted">@review.NgayTao.ToString("dd/MM/yyyy")</small>
                </div>
            }
        }
        else
        {
            <p>Chưa có đánh giá nào cho sản phẩm này.</p>
        }
    </div>

    <!-- Form gửi đánh giá -->
    <!-- Form gửi đánh giá -->
    <!-- Form gửi đánh giá -->
    
    </div>
<div class="pagination mt-4 d-flex justify-content-center align-items-center gap-2 flex-wrap">

    <!-- Nút PREV -->
    @if (ViewBag.CurrentPage > 1)
    {
        <a asp-action="Details"
           asp-route-id="@Model.MaSanPham"
           asp-route-page="@(ViewBag.CurrentPage - 1)"
           asp-route-star="@ViewBag.CurrentStar"
           asp-route-hasImage="@ViewBag.HasImage"
           class="btn btn-outline-dark">
            ← Prev
        </a>
    }
    else
    {
        <button class="btn btn-outline-dark" disabled>← Prev</button>
    }

    <!-- Số trang -->
    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a asp-action="Details"
           asp-route-id="@Model.MaSanPham"
           asp-route-page="@i"
           asp-route-star="@ViewBag.CurrentStar"
           asp-route-hasImage="@ViewBag.HasImage"
           class="btn @(i == ViewBag.CurrentPage ? "btn-dark" : "btn-outline-dark")">
            @i
        </a>
    }

    <!-- Nút NEXT -->
    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
    {
        <a asp-action="Details"
           asp-route-id="@Model.MaSanPham"
           asp-route-page="@(ViewBag.CurrentPage + 1)"
           asp-route-star="@ViewBag.CurrentStar"
           asp-route-hasImage="@ViewBag.HasImage"
           class="btn btn-outline-dark">
            Next →
        </a>
    }
    else
    {
        <button class="btn btn-outline-dark" disabled>Next →</button>
    }

</div>

<!-- Hiển thị Trang X / Y -->
<div class="text-center mt-2 text-muted">
    Trang @ViewBag.CurrentPage / @ViewBag.TotalPages
</div>
    <hr class="my-5" />

    <div class="related-section mb-4">
        <h3 class="fw-bold">Sản phẩm cùng loại</h3>
    </div>

    @if (sanPhamCungLoai.Any())
    {
        <div class="product-slider-wrapper related-slider-wrapper">
            <button class="slider-btn prev" type="button" onclick="scrollRelatedProducts(-1)">‹</button>

            <div class="product-slider related-product-slider" id="relatedProductSlider">
                @foreach (var item in sanPhamCungLoai)
                {
                    <div class="product-item">
                        <div class="card h-100 shadow-sm border-0">

                            @* PHẢI CÓ CLASS product-img-box Ở ĐÂY *@
                            <div class="product-img-box">
                                @if (item.DaBan < 20)
                                {
                                    <div class="promo-tag-fixed">
                                        -@item.PhanTramGiam%
                                    </div>
                                }

                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham">
                                    <img src="@item.HinhAnh" class="card-img-top p-2"
                                         style="height: 180px; object-fit: contain;">
                                </a>
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-truncate">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham" class="text-decoration-none text-dark">
                                        @item.TenSanPham
                                    </a>
                                </h5>

                                <div class="card-body d-flex flex-column">


                                    <div class="price-section">
                                        @if (item.DaBan < 20)
                                        {
                                            @* Hiển thị giá gốc bị gạch ngang *@
                                            <small class="text-muted text-decoration-line-through">
                                                @item.Gia.ToString("N0") VNĐ
                                            </small>
                                            @* Hiển thị giá sau giảm *@
                                            <p class="card-text text-danger fw-bold fs-5 mb-0">
                                                @item.GiaKhuyenMai.ToString("N0") VNĐ
                                            </p>
                                            @* Hiển thị phần trăm giảm *@

                                        }
                                        else
                                        {
                                            <p class="card-text text-danger fw-bold fs-5 mb-0">
                                                @item.Gia.ToString("N0") VNĐ
                                            </p>
                                        }
                                    </div>

                                    <div class="mt-2 d-flex justify-content-between align-items-center">
                                        <small class="text-muted">Đã bán: @item.DaBan</small>

                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(item.MauSac))
                                {
                                    <p class="mb-3 text-muted small">
                                        Màu sắc: @item.MauSac
                                    </p>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group mt-auto">
                                        <a asp-area="Admin"
                                           asp-controller="Product"
                                           asp-action="Edit"
                                           asp-route-id="@item.MaSanPham"
                                           class="btn btn-sm btn-outline-warning">
                                            Sửa
                                        </a>

                                        <form asp-area="Admin"
                                              asp-controller="Product"
                                              asp-action="Delete"
                                              asp-route-id="@item.MaSanPham"
                                              method="post"
                                              onsubmit="return confirm('Xóa sản phẩm?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger">
                                                Xóa
                                            </button>
                                        </form>
                                    </div>
                                }

                            </div>
                        </div>
                    </div>
                }
            </div>

            <button class="slider-btn next" type="button" onclick="scrollRelatedProducts(1)">›</button>
        </div>
    }
    else
    {
        <div class="col-12">
            <p class="text-muted">Không có sản phẩm cùng loại.</p>
        </div>
    }
</div>

<div id="cart-toast" class="cart-toast">Đã thêm vào giỏ hàng!</div>

<div id="imageModal" class="image-modal" onclick="closeImageModal()">
    <img id="modalImage" />
</div>


<script>
    function scrollRelatedProducts(direction) {
        const slider = document.getElementById("relatedProductSlider");
        if (!slider) return;

        const item = slider.querySelector(".product-item");
        if (!item) return;

        const itemWidth = item.offsetWidth;
        const gap = 18;
        const scrollAmount = itemWidth + gap;

        slider.scrollBy({
            left: direction * scrollAmount,
            behavior: "smooth"
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        const mainImage = document.getElementById("mainProductImage");
        const thumbs = document.querySelectorAll(".product-thumb");

        thumbs.forEach(img => {
            img.addEventListener("click", function () {
                mainImage.src = this.src;
                thumbs.forEach(t => t.classList.remove("active-thumb"));
                this.classList.add("active-thumb");
            });
        });

        function showCartToast(message, isError = false) {
            const toast = document.getElementById("cart-toast");
            if (!toast) return;

            toast.textContent = message;
            toast.style.background = isError ? "#dc3545" : "#198754";
            toast.classList.add("show");

            setTimeout(() => {
                toast.classList.remove("show");
            }, 2000);
        }

        async function addToCart(productId, quantity, redirectToCheckout = false) {
            try {
                const response = await fetch("/Cart/AddToCartAjax", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    body: `id=${productId}&quantity=${quantity}`
                });

                const result = await response.json();

                if (result.redirectToLogin) {
                    window.location.href = result.loginUrl;
                    return;
                }

                if (result.success) {
                    if (redirectToCheckout) {
                        window.location.href = "/Cart/Checkout";
                        return;
                    }

                    showCartToast(result.message || "Đã thêm vào giỏ hàng!");

                    const badge = document.getElementById("cart-badge");
                    if (badge) {
                        badge.textContent = result.cartCount;
                    }

                    const total = document.getElementById("cart-total");
                    if (total) {
                        total.textContent = Number(result.cartTotal).toLocaleString("vi-VN") + "đ";
                    }

                    const itemsContainer = document.getElementById("cart-dropdown-items");
                    if (itemsContainer && result.items) {
                        if (result.items.length > 0) {
                            let html = `<div style="max-height: 250px; overflow-y: auto;">`;

                            result.items.forEach(item => {
                                html += `
                                    <div class="d-flex align-items-center mb-3">
                                        <div style="width: 60px; height: 60px;" class="me-2">
                                            ${item.hinhAnh ? `<img src="${item.hinhAnh}" alt="${item.tenSanPham}" style="width:100%; height:100%; object-fit:contain;" />` : ``}
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">${item.tenSanPham}</div>
                                            <div class="text-muted small">SL: ${item.soLuong}</div>
                                        </div>
                                        <div class="text-danger fw-bold">
                                            ${Number(item.thanhTien).toLocaleString("vi-VN")}đ
                                        </div>
                                    </div>
                                `;
                            });

                            html += `</div>`;
                            itemsContainer.innerHTML = html;
                        } else {
                            itemsContainer.innerHTML = `<div class="py-3 text-center text-muted">Giỏ hàng trống</div>`;
                        }
                    }
                } else {
                    showCartToast(result.message || "Không thể thêm vào giỏ hàng!", true);
                }
            } catch (error) {
                console.error("AddToCartAjax error:", error);
                showCartToast("Có lỗi xảy ra khi thêm vào giỏ hàng!", true);
            }
        }

        const btnAddToCart = document.getElementById("btnAddToCart");
        const btnBuyNow = document.getElementById("btnBuyNow");
        const quantityInput = document.getElementById("quantityInput");

        if (btnAddToCart) {
            btnAddToCart.addEventListener("click", function () {
                const productId = this.dataset.id;
                const quantity = quantityInput ? quantityInput.value : 1;
                addToCart(productId, quantity, false);
            });
        }

        if (btnBuyNow) {
            btnBuyNow.addEventListener("click", function () {
                const productId = this.dataset.id;
                const quantity = quantityInput ? quantityInput.value : 1;
                addToCart(productId, quantity, true);
            });
        }

        document.querySelectorAll(".btn-add-related-to-cart").forEach(button => {
            button.addEventListener("click", function () {
                const productId = this.dataset.id;
                addToCart(productId, 1, false);
            });
        });
    });
        function openImageModal(src) {
        const modal = document.getElementById("imageModal");
        const img = document.getElementById("modalImage");

        img.src = src;
        modal.style.display = "flex";
    }

    function closeImageModal() {
        document.getElementById("imageModal").style.display = "none";
    }

    let currentStar = 0;
    let filterImage = false;
    let visibleCount = 10;

    function applyFilter() {
        const reviews = document.querySelectorAll(".review-item");
        let count = 0;
        let totalMatch = 0;

        reviews.forEach(r => {
            const star = parseInt(r.dataset.star);
            const hasImage = r.dataset.hasImage === "true";

            let match = true;

            if (currentStar !== 0 && star !== currentStar) match = false;
            if (filterImage && !hasImage) match = false;

            if (match) {
                totalMatch++;

                if (count < visibleCount) {
                    r.style.display = "block";
                    count++;
                } else {
                    r.style.display = "none";
                }
            } else {
                r.style.display = "none";
            }
        });

        // nút load more
        const btn = document.getElementById("btnLoadMore");
        if (btn) {
            btn.style.display = (visibleCount < totalMatch) ? "inline-block" : "none";
        }
    }

    // ===== EVENT =====

    // lọc sao
    document.getElementById("filterStar").addEventListener("change", function () {
        currentStar = parseInt(this.value);
        visibleCount = 10;
        applyFilter();
    });

    // lọc ảnh
    document.getElementById("filterImage").addEventListener("change", function () {
        filterImage = this.value === "true";
        visibleCount = 10;
        applyFilter();
    });

    // load thêm
    document.getElementById("btnLoadMore").addEventListener("click", function () {
        visibleCount += 10;
        applyFilter();
    });

    // chạy lần đầu
    document.addEventListener("DOMContentLoaded", function () {
        applyFilter();
    });

        function applyFilter() {
        const star = document.getElementById("filterStar").value;
        const hasImage = document.getElementById("filterImage").value;

        let url = `/Product/Details/@Model.MaSanPham?page=1`;

        if (star) url += `&star=${star}`;
        if (hasImage) url += `&hasImage=${hasImage}`;

        window.location.href = url;
    }
</script>