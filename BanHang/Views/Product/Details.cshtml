@model BanHang.Models.SanPham
@using BanHang.Models

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var sanPhamCungLoai = ViewBag.SanPhamCungLoai as List<SanPham> ?? new List<SanPham>();
    var dsAnh = Model.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any()
        ? Model.HinhAnhSanPhams
        : new List<HinhAnhSanPham>();

    int quantity = ViewBag.Quantity != null ? (int)ViewBag.Quantity : 1;
}
<link rel="stylesheet" href="~/css/productUser/Details.css" asp-append-version="true" />


<div class="container mt-4">
    <div class="row g-4">
        <div class="col-md-5">
            <div class="border rounded p-3 bg-white shadow-sm">
                <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "https://via.placeholder.com/500x400" : Model.HinhAnh)"
                     alt="@Model.TenSanPham"
                     class="img-fluid w-100"
                     style="height: 400px; object-fit: contain;" />
            </div>

            @if (dsAnh.Any())
            {
                <div class="row g-2 mt-3">
                    @foreach (var img in dsAnh)
                    {
                        <div class="col-3">
                            <img src="@img.DuongDanAnh"
                                 alt="@Model.TenSanPham"
                                 class="img-fluid border rounded"
                                 style="height: 90px; width: 100%; object-fit: contain;" />
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold mb-3">@Model.TenSanPham</h2>

            <p class="mb-2">
                <strong>Danh mục:</strong> @(Model.DanhMuc?.TenDanhMuc ?? "Chưa có")
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.MauSac))
            {
                <p class="mb-2">
                    <strong>Màu sắc:</strong> @Model.MauSac
                </p>
            }

            <p class="text-danger fw-bold fs-3 mb-3">
                @Model.Gia.ToString("N0") VNĐ
            </p>

            <div class="mb-4">
                <strong>Mô tả:</strong>
                <div class="mt-2 text-muted">
                    @(string.IsNullOrWhiteSpace(Model.MoTa) ? "Chưa có mô tả sản phẩm." : Model.MoTa)
                </div>
            </div>

            <div class="mb-3">
                <span class="btn btn-sm btn-outline-success disabled">
                    Đã bán @Model.DaBan
                </span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="Admin"
                       asp-controller="Product"
                       asp-action="Edit"
                       asp-route-id="@Model.MaSanPham"
                       class="btn btn-warning">
                        Sửa sản phẩm
                    </a>
                }
                else if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <form asp-controller="Product" asp-action="Details" method="get" class="d-inline">
                            <input type="hidden" name="id" value="@Model.MaSanPham" />
                            <input type="hidden" name="quantity" value="@(quantity > 1 ? quantity - 1 : 1)" />
                            <button type="submit" class="btn btn-outline-secondary">-</button>
                        </form>

                        <input type="text"
                               id="quantityInput"
                               value="@quantity"
                               class="form-control text-center"
                               style="width: 80px;"
                               readonly />

                        <form asp-controller="Product" asp-action="Details" method="get" class="d-inline">
                            <input type="hidden" name="id" value="@Model.MaSanPham" />
                            <input type="hidden" name="quantity" value="@(quantity + 1)" />
                            <button type="submit" class="btn btn-outline-secondary">+</button>
                        </form>

                        <button type="button"
                                id="btnAddToCart"
                                data-id="@Model.MaSanPham"
                                class="btn btn-dark">
                            Thêm vào giỏ hàng
                        </button>
                    </div>
                }
                else
                {
                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@Context.Request.Path"
                       class="btn btn-outline-dark">
                        Thêm vào giỏ hàng
                    </a>
                }

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Quay lại
                </a>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <div class="mb-4">
        <h3 class="fw-bold">Sản phẩm cùng loại</h3>
    </div>

    <div class="row">
        @if (sanPhamCungLoai.Any())
        {
            @foreach (var item in sanPhamCungLoai)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@item.MaSanPham"
                           class="text-decoration-none">
                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                                 class="card-img-top p-2"
                                 alt="@item.TenSanPham"
                                 style="height: 180px; object-fit: contain;" />
                        </a>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">
                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.MaSanPham"
                                   class="text-decoration-none text-dark">
                                    @item.TenSanPham
                                </a>
                            </h5>

                            <p class="card-text text-danger fw-bold fs-5">
                                @item.Gia.ToString("N0") VNĐ
                            </p>

                            <div class="mt-auto d-grid gap-2">
                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.MaSanPham"
                                   class="btn btn-outline-primary">
                                    Xem chi tiết
                                </a>

                                @if (!User.IsInRole("Admin"))
                                {
                                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <button type="button"
                                                class="btn btn-dark btn-add-related-to-cart"
                                                data-id="@item.MaSanPham">
                                            Thêm vào giỏ
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-area="Identity"
                                           asp-page="/Account/Login"
                                           asp-route-returnUrl="@Context.Request.Path"
                                           class="btn btn-outline-dark">
                                            Thêm vào giỏ
                                        </a>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <p class="text-muted">Không có sản phẩm cùng loại.</p>
            </div>
        }
    </div>
</div>

<div id="cart-toast" class="cart-toast">Đã thêm vào giỏ hàng!</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function showCartToast(message, isError = false) {
                const toast = document.getElementById("cart-toast");
                if (!toast) return;

                toast.textContent = message;
                toast.style.background = isError ? "#dc3545" : "#198754";
                toast.classList.add("show");

                setTimeout(() => {
                    toast.classList.remove("show");
                }, 2000);
            }

            async function addToCart(productId, quantity) {
                try {
                    const response = await fetch("/Cart/AddToCartAjax", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                            "X-Requested-With": "XMLHttpRequest"
                        },
                        body: `id=${productId}&quantity=${quantity}`
                    });

                    const result = await response.json();

                    if (result.redirectToLogin) {
                        window.location.href = result.loginUrl;
                        return;
                    }

                    if (result.success) {
                        showCartToast(result.message || "Đã thêm vào giỏ hàng!");

                        const badge = document.getElementById("cart-badge");
                        if (badge) {
                            badge.textContent = result.cartCount;
                        }

                        const total = document.getElementById("cart-total");
                        if (total) {
                            total.textContent = Number(result.cartTotal).toLocaleString("vi-VN") + "đ";
                        }

                        const itemsContainer = document.getElementById("cart-dropdown-items");
                        if (itemsContainer && result.items) {
                            if (result.items.length > 0) {
                                let html = `<div style="max-height: 250px; overflow-y: auto;">`;

                                result.items.forEach(item => {
                                    html += `
                                        <div class="d-flex align-items-center mb-3">
                                            <div style="width: 60px; height: 60px;" class="me-2">
                                                ${item.hinhAnh ? `<img src="${item.hinhAnh}" alt="${item.tenSanPham}" style="width:100%; height:100%; object-fit:contain;" />` : ``}
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="fw-semibold">${item.tenSanPham}</div>
                                                <div class="text-muted small">SL: ${item.soLuong}</div>
                                            </div>
                                            <div class="text-danger fw-bold">
                                                ${Number(item.thanhTien).toLocaleString("vi-VN")}đ
                                            </div>
                                        </div>
                                    `;
                                });

                                html += `</div>`;
                                itemsContainer.innerHTML = html;
                            } else {
                                itemsContainer.innerHTML = `<div class="py-3 text-center text-muted">Giỏ hàng trống</div>`;
                            }
                        }
                    } else {
                        showCartToast(result.message || "Không thể thêm vào giỏ hàng!", true);
                    }
                } catch (error) {
                    console.error("AddToCartAjax error:", error);
                    showCartToast("Có lỗi xảy ra khi thêm vào giỏ hàng!", true);
                }
            }

            const btnAddToCart = document.getElementById("btnAddToCart");
            const quantityInput = document.getElementById("quantityInput");

            if (btnAddToCart) {
                btnAddToCart.addEventListener("click", function () {
                    const productId = this.dataset.id;
                    const quantity = quantityInput ? quantityInput.value : 1;
                    addToCart(productId, quantity);
                });
            }

            document.querySelectorAll(".btn-add-related-to-cart").forEach(button => {
                button.addEventListener("click", function () {
                    const productId = this.dataset.id;
                    addToCart(productId, 1);
                });
            });
        });
    </script>
}