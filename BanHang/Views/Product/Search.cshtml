@model IEnumerable<BanHang.Models.SanPham>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}
<link rel="stylesheet" href="~/css/Search.css" asp-append-version="true" />

<div class="container mt-4 search-product-page">
    <div class="search-header">
        <h2>Kết quả tìm kiếm</h2>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Keyword as string))
        {
            <p>
                Từ khóa: <strong>@ViewBag.Keyword</strong>
            </p>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 col-sm-6 product-item">
                    <div class="product-card">
                        <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@item.MaSanPham"
                               class="product-thumb">
                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/300x300" : item.HinhAnh)"
                                 alt="@item.TenSanPham" />
                        </a>

                        <div class="product-body">
                            <h5 class="product-name">
                                <a asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@item.MaSanPham">
                                    @item.TenSanPham
                                </a>
                            </h5>

                            <div class="product-meta">
                                <p class="product-price">@item.Gia.ToString("N0") VNĐ</p>
                                <p class="product-sold">Đã bán @(item.DaBan)</p>
                            </div>

                            <p class="product-color">
                                Màu sắc: @(string.IsNullOrEmpty(item.MauSac) ? "Chưa có" : item.MauSac)
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-result">
            Không tìm thấy sản phẩm phù hợp.
        </div>
    }
</div>