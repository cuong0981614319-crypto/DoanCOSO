@model IEnumerable<BanHang.Models.SanPham>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">Kết quả tìm kiếm</h2>

        @if (!string.IsNullOrWhiteSpace(ViewBag.Keyword as string))
        {
            <p class="text-muted mb-0">
                Từ khóa: <strong>@ViewBag.Keyword</strong>
            </p>
        }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <a asp-controller="Product"
                           asp-action="Details"
                           asp-route-id="@item.MaSanPham"
                           class="text-decoration-none">
                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                                 class="card-img-top p-2"
                                 alt="@item.TenSanPham"
                                 style="height:220px; object-fit:contain;" />
                        </a>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.MaSanPham"
                                   class="text-decoration-none text-dark">
                                    @item.TenSanPham
                                </a>
                            </h5>

                            <p class="card-text text-danger fw-bold fs-5">
                                @item.Gia.ToString("N0") VNĐ
                            </p>

                            <p class="text-muted small mb-3">
                                Danh mục: @(item.DanhMuc?.TenDanhMuc ?? "Chưa có")
                            </p>

                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@item.MaSanPham"
                               class="btn btn-dark mt-auto">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            Không tìm thấy sản phẩm phù hợp.
        </div>
    }
</div>