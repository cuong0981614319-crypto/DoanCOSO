@model dynamic
@{
    ViewData["Title"] = "Đánh giá sản phẩm";
    var productName = ViewBag.ProductName as string ?? "Sản phẩm";
    var productPrice = ViewBag.ProductPrice;
    var productId = ViewBag.ProductId;
}

<div class="product-review-container">
    <!-- Product Header -->
    <div class="product-header">
        <div class="product-image">
            @if (ViewBag.ProductImage != null)
            {
                <img src="@ViewBag.ProductImage" style="width:100%; height:100%; object-fit:cover; border-radius:15px;" />
            }
            else
            {
                <i class="fas fa-mobile-alt"></i>
            }
        </div>
        <div class="product-title">@productName</div>
        <div class="product-price">@(productPrice != null ? string.Format("{0:N0}đ", productPrice) : "")</div>
    </div>

    <!-- Review Form -->
    <div class="review-form">
        @* Đảm bảo asp-action và asp-controller khớp chính xác với code C# của bạn *@
        <form asp-action="AddReview" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="sanPhamId" value="@ViewBag.ProductId" />

            <div class="mb-3">
                <label>Điểm:</label>
                <select name="diem" class="form-control">
                    <option value="5">5 ⭐</option>
                    <option value="4">4 ⭐</option>
                    <option value="3">3 ⭐</option>
                    <option value="2">2 ⭐</option>
                    <option value="1">1 ⭐</option>
                </select>
            </div>

            <div class="mb-3">
                <label>Nội dung:</label>
                <textarea name="noiDung" class="form-control"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
        </form>
    </div>

    <!-- Reviews List -->
    
</div>

@section Scripts {
    <script>
           <script>
        setTimeout(() => {
            const alert = document.getElementById('successAlert');
            if (alert) {
                alert.style.transition = "0.5s";
                alert.style.opacity = "0";
                setTimeout(() => alert.remove(), 500);
            }
        }, 2000);
    </script>
    </script>
}

<style>
    /* Tổng thể container */
    .product-review-container {
        max-width: 800px;
        margin: 20px auto;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Header sản phẩm */
    .product-header {
        background: linear-gradient(135deg, #ff6b6b, #feca57);
        padding: 30px;
        text-align: center;
        color: white;
    }

    .product-image {
        width: 100px;
        height: 100px;
        background: rgba(255,255,255,0.2);
        border-radius: 15px;
        margin: 0 auto 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        overflow: hidden;
    }

    .product-title {
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    /* Form đánh giá */
    .review-form {
        padding: 30px;
        border-bottom: 1px solid #eee;
    }

    .form-label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: #333;
    }

    /* CSS CHO PHẦN CHỌN SAO MỚI */
    .star-rating-wrapper {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 30px;
            color: #ddd;
            cursor: pointer;
            transition: 0.2s;
            padding: 0 2px;
        }

            /* Hiệu ứng khi hover hoặc check */
            .star-rating label:hover,
            .star-rating label:hover ~ label,
            .star-rating input:checked ~ label {
                color: #ffd700;
            }

    .rating-label {
        font-weight: 600;
        color: #764ba2;
        font-size: 14px;
        background: #f0eaff;
        padding: 4px 12px;
        border-radius: 20px;
    }

    /* Textarea và nút bấm */
    .review-textarea {
        width: 100%;
        min-height: 120px;
        padding: 15px;
        border: 2px solid #eee;
        border-radius: 12px;
        resize: none;
        transition: 0.3s;
    }

        .review-textarea:focus {
            border-color: #764ba2;
            outline: none;
        }

    .char-counter {
        display: block;
        text-align: right;
        font-size: 12px;
        color: #888;
        margin-top: 5px;
    }

    .submit-btn {
        background: #764ba2;
        color: white;
        border: none;
        padding: 15px;
        border-radius: 30px;
        width: 100%;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 15px;
    }

        .submit-btn:hover {
            background: #5a368c;
            transform: translateY(-2px);
        }

    /* Danh sách review */
    .reviews-list {
        padding: 30px;
        background: #fdfdfd;
    }

    .review-item {
        display: flex;
        gap: 15px;
        padding: 20px 0;
        border-bottom: 1px solid #eee;
    }

    .review-avatar {
        width: 45px;
        height: 45px;
        background: #764ba2;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        flex-shrink: 0;
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 5px;
    }

    .reviewer-name {
        font-weight: 700;
        color: #333;
    }

    .review-date {
        font-size: 12px;
        color: #999;
    }

    .review-text {
        color: #555;
        margin-top: 8px;
        line-height: 1.5;
    }
</style>