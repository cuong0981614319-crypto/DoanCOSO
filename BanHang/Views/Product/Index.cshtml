@model IEnumerable<BanHang.Models.SanPham>

@{
    
    var danhMucs = ViewBag.DanhMucs as List<BanHang.Models.DanhMuc>;
    var mauSacs = ViewBag.MauSacs as List<string>;
    var kichThuocs = ViewBag.KichThuocs as List<string>;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}
<link rel="stylesheet" href="~/css/productUser/index.css" asp-append-version="true" />


<div class="container mt-4 product-index-moho">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">@ViewBag.TenKhuVuc</h2>
     
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-controller="Product" asp-action="Index" method="get" class="row g-3 align-items-end">
                <input type="hidden" name="khuVucId" value="@ViewBag.KhuVucId" />

                <div class="col-md-3 col-sm-6">
                    <label class="form-label fw-semibold">Danh mục</label>
                    <select name="maDanhMuc" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả danh mục --</option>

                        @{
                            // Lấy danh sách từ ViewBag đã nạp ở Controller
                            var danhMucs = ViewBag.DanhMucs as List<BanHang.Models.DanhMuc>;
                        }

                        @if (danhMucs != null)
                        {
                            @foreach (var dm in danhMucs)
                            {
                                // Kiểm tra nếu MaDanhMuc này đang được chọn thì thêm thuộc tính selected
                                if (ViewBag.CurrentMaDanhMuc != null && (int)ViewBag.CurrentMaDanhMuc == dm.MaDanhMuc)
                                {
                                    <option value="@dm.MaDanhMuc" selected>@dm.TenDanhMuc</option>
                                }
                                else
                                {
                                    <option value="@dm.MaDanhMuc">@dm.TenDanhMuc</option>
                                }
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3 col-sm-6">
                    <label class="form-label fw-semibold">Giá sản phẩm</label>
                    <select name="mucGia" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả mức giá --</option>

                        @if ((string?)ViewBag.MucGia == "duoi1tr")
                        {
                            <option value="duoi1tr" selected>Dưới 1 triệu</option>
                        }
                        else
                        {
                            <option value="duoi1tr">Dưới 1 triệu</option>
                        }

                        @if ((string?)ViewBag.MucGia == "1tr-5tr")
                        {
                            <option value="1tr-5tr" selected>Từ 1 - 5 triệu</option>
                        }
                        else
                        {
                            <option value="1tr-5tr">Từ 1 - 5 triệu</option>
                        }

                        @if ((string?)ViewBag.MucGia == "5tr-10tr")
                        {
                            <option value="5tr-10tr" selected>Từ 5 - 10 triệu</option>
                        }
                        else
                        {
                            <option value="5tr-10tr">Từ 5 - 10 triệu</option>
                        }

                        @if ((string?)ViewBag.MucGia == "tren10tr")
                        {
                            <option value="tren10tr" selected>Trên 10 triệu</option>
                        }
                        else
                        {
                            <option value="tren10tr">Trên 10 triệu</option>
                        }
                    </select>
                </div>

               
               

                <div class="col-md-3 col-sm-6">
                    <a asp-controller="Product"
                       asp-action="Index"
                       asp-route-khuVucId="@ViewBag.KhuVucId"
                       class="btn btn-outline-secondary">
                        Xóa bộ lọc
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="product-item">
                    <div class="card h-100 shadow-sm border-0">

                        @* PHẢI CÓ CLASS product-img-box Ở ĐÂY *@
                        <div class="product-img-box">
                            @if (item.DaBan < 20)
                            {
                                <div class="promo-tag-fixed">
                                    -@item.PhanTramGiam%
                                </div>
                            }

                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham">
                                <img src="@item.HinhAnh" class="card-img-top p-2"
                                     style="height: 180px; object-fit: contain;">
                            </a>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham" class="text-decoration-none text-dark">
                                    @item.TenSanPham
                                </a>
                            </h5>

                            <div class="card-body d-flex flex-column">


                                <div class="price-section">
                                    @if (item.DaBan < 20)
                                    {
                                        @* Hiển thị giá gốc bị gạch ngang *@
                                        <small class="text-muted text-decoration-line-through">
                                            @item.Gia.ToString("N0") VNĐ
                                        </small>
                                        @* Hiển thị giá sau giảm *@
                                        <p class="card-text text-danger fw-bold fs-5 mb-0">
                                            @item.GiaKhuyenMai.ToString("N0") VNĐ
                                        </p>
                                        @* Hiển thị phần trăm giảm *@

                                    }
                                    else
                                    {
                                        <p class="card-text text-danger fw-bold fs-5 mb-0">
                                            @item.Gia.ToString("N0") VNĐ
                                        </p>
                                    }
                                </div>

                                <div class="mt-2 d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Đã bán: @item.DaBan</small>

                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(item.MauSac))
                            {
                                <p class="mb-3 text-muted small">
                                    Màu sắc: @item.MauSac
                                </p>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="btn-group mt-auto">
                                    <a asp-area="Admin"
                                       asp-controller="Product"
                                       asp-action="Edit"
                                       asp-route-id="@item.MaSanPham"
                                       class="btn btn-sm btn-outline-warning">
                                        Sửa
                                    </a>

                                    <form asp-area="Admin"
                                          asp-controller="Product"
                                          asp-action="Delete"
                                          asp-route-id="@item.MaSanPham"
                                          method="post"
                                          onsubmit="return confirm('Xóa sản phẩm?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger">
                                            Xóa
                                        </button>
                                    </form>
                                </div>
                            }
                          
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center flex-wrap">

                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-khuVucId="@ViewBag.KhuVucId"
                           asp-route-maDanhMuc="@ViewBag.MaDanhMuc"
                           asp-route-mucGia="@ViewBag.MucGia"
                           asp-route-mauSac="@ViewBag.MauSac">
                            «
                        </a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-khuVucId="@ViewBag.KhuVucId"
                               asp-route-maDanhMuc="@ViewBag.MaDanhMuc"
                               asp-route-mucGia="@ViewBag.MucGia"
                               asp-route-mauSac="@ViewBag.MauSac">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-khuVucId="@ViewBag.KhuVucId"
                           asp-route-maDanhMuc="@ViewBag.MaDanhMuc"
                           asp-route-mucGia="@ViewBag.MucGia"
                           asp-route-mauSac="@ViewBag.MauSac">
                            »
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted fs-5">Không có sản phẩm phù hợp</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".btn-add-to-cart").forEach(btn => {
                btn.addEventListener("click", async function () {
                    const id = this.dataset.id;

                    try {
                        const res = await fetch("/Cart/AddToCartAjax", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            body: `id=${id}&quantity=1`
                        });

                        const result = await res.json();

                        if (result.redirectToLogin) {
                            window.location.href = result.loginUrl;
                            return;
                        }

                        if (result.success) {
                            const badge = document.getElementById("cart-badge");
                            if (badge) {
                                badge.textContent = result.cartCount;
                            }

                            const total = document.getElementById("cart-total");
                            if (total) {
                                total.textContent = Number(result.cartTotal).toLocaleString("vi-VN") + "đ";
                            }

                            const itemsContainer = document.getElementById("cart-dropdown-items");
                            if (itemsContainer && result.items) {
                                if (result.items.length > 0) {
                                    let html = `<div style="max-height: 250px; overflow-y: auto;">`;

                                    result.items.forEach(item => {
                                        html += `
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 60px; height: 60px;" class="me-2">
                                                    ${item.hinhAnh ? `<img src="${item.hinhAnh}" alt="${item.tenSanPham}" style="width:100%; height:100%; object-fit:contain;" />` : ``}
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">${item.tenSanPham}</div>
                                                    <div class="text-muted small">SL: ${item.soLuong}</div>
                                                </div>
                                                <div class="text-danger fw-bold">
                                                    ${Number(item.thanhTien).toLocaleString("vi-VN")}đ
                                                </div>
                                            </div>
                                        `;
                                    });

                                    html += `</div>`;
                                    itemsContainer.innerHTML = html;
                                } else {
                                    itemsContainer.innerHTML = `<div class="py-3 text-center text-muted">Giỏ hàng trống</div>`;
                                }
                            }
                        }
                    } catch (error) {
                        console.error("AddToCartAjax error:", error);
                    }
                });
            });
        });
    </script>
}