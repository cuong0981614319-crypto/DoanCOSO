@model BanHang.Models.ThanhToan

@{
    // Ép kiểu chuẩn để không bị lỗi GiaKhuyenMai = 0
    var gioHang = ViewBag.GioHang as List<CartItem> ?? new List<CartItem>();

    decimal tongTienGoc = gioHang.Sum(x => x.Gia * x.SoLuong);
    decimal tongTienSauGiam = gioHang.Sum(x => x.ThanhTien);
    decimal tietKiem = tongTienGoc - tongTienSauGiam;
}

<div class="container mt-4 checkout-page">
    <h2 class="mb-4 fw-bold">Thanh toán</h2>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h4 class="mb-4 fw-bold"><i class="bi bi-geo-alt me-2"></i>Thông tin nhận hàng</h4>

                    <form asp-action="Checkout" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="HoTen" class="form-label fw-semibold">Họ Tên</label>
                            <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên người nhận" />
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="SoDienThoai" class="form-label fw-semibold">Số Điện Thoại</label>
                                <input asp-for="SoDienThoai" class="form-control" placeholder="Số điện thoại liên hệ" />
                                <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                <input asp-for="Email" class="form-control" placeholder="Địa chỉ email (không bắt buộc)" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi" class="form-label fw-semibold">Địa Chỉ Nhận Hàng</label>
                            <textarea asp-for="DiaChi" class="form-control" rows="2" placeholder="Số nhà, tên đường, phường/xã..."></textarea>
                            <span asp-validation-for="DiaChi" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GhiChu" class="form-label fw-semibold">Ghi Chú Đơn Hàng</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="2" placeholder="Lưu ý cho người giao hàng"></textarea>
                            <span asp-validation-for="GhiChu" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PhuongThucThanhToan" class="form-label fw-semibold">Phương thức thanh toán</label>
                            <select asp-for="PhuongThucThanhToan" class="form-select border-primary-subtle">
                                <option value="">-- Chọn phương thức --</option>
                                <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                                <option value="Bank">Chuyển khoản ngân hàng</option>
                                <option value="MOMO">Ví điện tử MoMo</option>
                                <option value="VNPAY">Cổng thanh toán VNPAY</option>
                            </select>
                            <span asp-validation-for="PhuongThucThanhToan" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold shadow-sm">ĐẶT HÀNG NGAY</button>
                            <a asp-controller="Cart" asp-action="Index" class="btn btn-link text-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại giỏ hàng
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                <div class="card-body p-4">
                    <h4 class="mb-4 fw-bold">Đơn hàng của bạn (@(gioHang?.Count() ?? 0) sản phẩm)</h4>

                    @if (gioHang != null && gioHang.Any())
                    {
                        <div class="checkout-products mb-4" style="max-height: 400px; overflow-y: auto;">
                            @foreach (var item in gioHang)
                            {
                                decimal gGoc = Convert.ToDecimal(item.Gia);
                                decimal gKM = gGoc;
                                try { gKM = Convert.ToDecimal(item.GiaKhuyenMai); } catch { }
                                int sL = Convert.ToInt32(item.SoLuong);

                                <div class="checkout-product-item d-flex align-items-center mb-3 pb-3 border-bottom">
                                    <div class="product-image me-3 position-relative">
                                        <img src="@(item.HinhAnh ?? "/images/no-image.png")"
                                             alt="@item.TenSanPham"
                                             class="img-fluid rounded border" />
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary" style="font-size: 0.7rem;">
                                            @sL
                                        </span>
                                    </div>

                                    <div class="flex-grow-1 ms-2">
                                        <div class="fw-semibold text-truncate" style="max-width: 180px;">@(item.TenSanPham)</div>
                                    
                                    </div>

                                    <div class="text-end">
                                        <div class="fw-bold text-danger">
                                            @String.Format("{0:N0}đ", gKM * sL)
                                        </div>
                                        @if (gGoc > gKM)
                                        {
                                            <div class="text-muted text-decoration-line-through small">
                                                @String.Format("{0:N0}đ", gGoc * sL)
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="summary-section bg-light p-3 rounded">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tổng giá gốc</span>
                                <span class="text-muted text-decoration-line-through">@tongTienGoc.ToString("N0")đ</span>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="fw-bold text-dark">Tiết kiệm được</span>
                                <span class="text-success fw-bold">
                                    @if (tietKiem > 0)
                                    {
                                        <text>-</text>
                                    }
                                    @tietKiem.ToString("N0")đ
                                </span>
                            </div>

                            <hr />

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold fs-5">TỔNG CỘNG</span>
                                <div class="text-end">
                                    <div class="text-danger fw-bold fs-4">@tongTienSauGiam.ToString("N0")đ</div>
                                    <small class="text-muted">(Đã bao gồm VAT)</small>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-cart-x fs-1 text-muted"></i>
                            <p class="mt-2">Giỏ hàng trống rỗng</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .checkout-page {
        max-width: 1280px;
    }

        .checkout-page .card {
            border-radius: 12px;
        }

        .checkout-page .form-control,
        .checkout-page .form-select {
            min-height: 46px;
        }

        .checkout-page textarea.form-control {
            min-height: unset;
        }

    .checkout-product-item .product-image {
        width: 72px;
        height: 72px;
        flex: 0 0 72px;
        overflow: hidden;
        background: #f8f8f8;
    }

        .checkout-product-item .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}