@model BanHang.Models.DonHang

<h2>Chi tiết đơn hàng #@Model.MaDonHang</h2>

<p>Khách: @Model.HoTenNguoiNhan</p>
<p>Thanh toán: @Model.PhuongThucThanhToan</p>

<table class="table">
    <tr>
        <th>Sản phẩm</th>
        <th>Số lượng</th>
        <th>Giá</th>
    </tr>

    @foreach (var item in Model.ChiTietDonHangs)
    {
        <tr>
            <td>@item.SanPham.TenSanPham</td>
            <td>@item.SoLuong</td>
            <td>@item.DonGia</td>
        </tr>
    }
</table>