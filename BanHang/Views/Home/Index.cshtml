@model IEnumerable<BanHang.Models.KhuVucHienThi>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container-fluid p-0">
    <div id="homeSlider" class="carousel slide carousel-fade banner-slider" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c"
                         class="w-100"
                         style="height:500px; object-fit:cover;">
                    <div class="position-absolute top-50 start-0 translate-middle-y text-white ps-5">
                        <h2 class="fw-bold">HỆ TỦ QUẦN ÁO CÁNH KÍNH</h2>
                        <h1 class="display-1 fw-bold">ASTRO</h1>
                        <p class="fs-4">Trải Nghiệm Chọn Trang Phục Đẳng Cấp Hơn</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mt-4">

    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex justify-content-end gap-2 mb-4 flex-wrap">
            <a asp-area="Admin"
                   asp-controller="Product"
                   asp-action="Index"
                   class="btn btn-primary">
                📦 Quản lý sản phẩm
            </a>

            <a asp-area="Admin"
                   asp-controller="DanhMuc"
                   asp-action="Index"
                   class="btn btn-warning text-dark">
                Quản lý danh mục
            </a>

            <a asp-area="Admin"
                   asp-controller="KhuVuc"
                   asp-action="Index"
                   class="btn btn-success">
                Quản lý khu vực
            </a>

            <a asp-area="Admin"
                   asp-controller="DonHang"
                   asp-action="Index"
                   class="btn btn-dark">
                Quản lý đơn hàng
            </a>
        </div>
    }

    @foreach (var kv in Model.OrderBy(x => x.ThuTu))
    {
        <div class="mb-4">
            <h2 class="fw-bold">@kv.Ten</h2>
        </div>

        <div class="row">
            @if (kv.SanPhams != null && kv.SanPhams.Any())
            {
                @foreach (var item in kv.SanPhams)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card h-100 shadow-sm border-0">
                            <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.MaSanPham"
                                   class="text-decoration-none">
                                <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                                     class="card-img-top p-2"
                                     alt="@item.TenSanPham"
                                     style="height: 180px; object-fit: contain;">
                            </a>

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-truncate">
                                    <a asp-controller="Product"
                                           asp-action="Details"
                                           asp-route-id="@item.MaSanPham"
                                           class="text-decoration-none text-dark">
                                        @item.TenSanPham
                                    </a>
                                </h5>

                                <p class="card-text text-danger fw-bold fs-5">
                                    @item.Gia.ToString("N0") VNĐ
                                </p>

                                <div class="mt-auto d-grid gap-2">
                                   

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="btn-group">
                                            <a asp-area="Admin"
                                                   asp-controller="Product"
                                                   asp-action="Edit"
                                                   asp-route-id="@item.MaSanPham"
                                                   class="btn btn-sm btn-outline-warning">
                                                Sửa
                                            </a>

                                            <form asp-area="Admin"
                                                  asp-controller="Product"
                                                  asp-action="Delete"
                                                  asp-route-id="@item.MaSanPham"
                                                  method="post"
                                                  onsubmit="return confirm('Xóa sản phẩm?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger">
                                                    Xóa
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <button type="button"
                                                class="btn btn-dark btn-add-to-cart"
                                                data-id="@item.MaSanPham">
                                            Thêm vào giỏ
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-area="Identity"
                                               asp-page="/Account/Login"
                                               asp-route-returnUrl="@Context.Request.Path"
                                               class="btn btn-outline-dark">
                                            Thêm vào giỏ
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-4">
                    <p class="text-muted">Chưa có sản phẩm</p>
                </div>
            }
        </div>

        <hr class="my-5" />
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const buttons = document.querySelectorAll(".btn-add-to-cart");

            buttons.forEach(button => {
                button.addEventListener("click", async function () {
                    const productId = this.dataset.id;

                    try {
                        const response = await fetch("/Cart/AddToCartAjax", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            body: `id=${productId}&quantity=1`
                        });

                        const result = await response.json();

                        if (result.redirectToLogin) {
                            window.location.href = result.loginUrl;
                            return;
                        }

                        if (result.success) {
                            const badge = document.getElementById("cart-badge");
                            if (badge) {
                                badge.textContent = result.cartCount;
                            }

                            const total = document.getElementById("cart-total");
                            if (total) {
                                total.textContent = Number(result.cartTotal).toLocaleString("vi-VN") + "đ";
                            }

                            const itemsContainer = document.getElementById("cart-dropdown-items");
                            if (itemsContainer) {
                                if (result.items && result.items.length > 0) {
                                    let html = `<div style="max-height: 250px; overflow-y: auto;">`;

                                    result.items.forEach(item => {
                                        html += `
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 60px; height: 60px;" class="me-2">
                                                    ${item.hinhAnh ? `<img src="${item.hinhAnh}" alt="${item.tenSanPham}" style="width:100%; height:100%; object-fit:contain;" />` : ``}
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">${item.tenSanPham}</div>
                                                    <div class="text-muted small">SL: ${item.soLuong}</div>
                                                </div>
                                                <div class="text-danger fw-bold">
                                                    ${Number(item.thanhTien).toLocaleString("vi-VN")}đ
                                                </div>
                                            </div>
                                        `;
                                    });

                                    html += `</div>`;
                                    itemsContainer.innerHTML = html;
                                } else {
                                    itemsContainer.innerHTML = `<div class="py-3 text-center text-muted">Giỏ hàng trống</div>`;
                                }
                            }
                        }
                    } catch (error) {
                        console.error("AddToCartAjax error:", error);
                    }
                });
            });
        });
    </script>
}