@model IEnumerable<BanHang.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container-fluid p-0">
    <div id="homeSlider" class="carousel slide carousel-fade banner-slider" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c" class="w-100" style="height:500px; object-fit:cover;">
                    <div class="position-absolute top-50 start-0 translate-middle-y text-white ps-5">
                        <h2 class="fw-bold">HỆ TỦ QUẦN ÁO CÁNH KÍNH</h2>
                        <h1 class="display-1 fw-bold">ASTRO</h1>
                        <p class="fs-4">Trải Nghiệm Chọn Trang Phục Đẳng Cấp Hơn</p>
                        <a class="btn btn-light btn-lg mt-3">Xem Chi Tiết</a>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0" class="w-100" style="height:500px; object-fit:cover;">
                    <div class="position-absolute top-50 start-0 translate-middle-y text-white ps-5">
                        <h2 class="fw-bold">NỘI THẤT HIỆN ĐẠI</h2>
                        <h1 class="display-1 fw-bold">MODERN</h1>
                        <p class="fs-4">Thiết kế tinh tế cho không gian sống</p>
                        <a class="btn btn-light btn-lg mt-3">Khám phá</a>
                    </div>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</div>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">🛒 Sản phẩm nổi bật</h1>
        
        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-primary shadow-sm">
                + Thêm sản phẩm mới
            </a>
        }
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        @* Sử dụng thuộc tính HinhAnh từ database, nếu trống thì dùng ảnh mặc định *@
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                             class="card-img-top p-2"
                             alt="@item.TenSanPham"
                             style="height: 200px; object-fit: contain;">
                        
                        <div class="card-body d-flex flex-column">
                            @* Đổi thành TenSanPham *@
                            <h5 class="card-title text-truncate">@item.TenSanPham</h5>
                            @* Đổi thành Gia *@
                            <p class="card-text text-danger fw-bold fs-5">@item.Gia.ToString("N0") VNĐ</p>
                            
                            <div class="mt-auto d-grid gap-2">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group">
                                        @* Sử dụng MaSanPham thay cho Id *@
                                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@item.MaSanPham"
                                           class="btn btn-sm btn-outline-warning">Sửa</a>
                                        
                                        @* Lưu ý: Delete thường là POST, nếu dùng thẻ <a> cần dùng form hoặc JS *@
                                        <form asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@item.MaSanPham"
                                              method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Xóa</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Cart"
                                           asp-action="AddToCart"
                                           asp-route-id="@item.MaSanPham"
                                           class="btn btn-dark">
                                        Thêm vào giỏ
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Chưa có sản phẩm nào được đăng bán.</p>
            </div>
        }
    </div>
</div>