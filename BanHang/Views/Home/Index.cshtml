@model IEnumerable<BanHang.Models.KhuVucHienThi>

@{
    ViewData["Title"] = "Trang chủ";
}
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />



<div class="container-fluid p-0">
    <div id="homeSlider" class="carousel slide carousel-fade" data-bs-ride="carousel">

        <div class="carousel-indicators">
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c"
                     class="banner-img">
                <div class="carousel-caption d-flex flex-column align-items-start justify-content-center h-100">
                    <h2>HỆ TỦ QUẦN ÁO CÁNH KÍNH</h2>
                    <h1 class="display-3 fw-bold">ASTRO</h1>
                    <p>Trải Nghiệm Chọn Trang Phục Đẳng Cấp Hơn</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0"
                     class="banner-img">
                <div class="carousel-caption d-flex flex-column align-items-start justify-content-center h-100">
                    <h2>NỘI THẤT HIỆN ĐẠI</h2>
                    <h1 class="display-3 fw-bold">MOHO</h1>
                    <p>Thiết kế tối giản - sang trọng</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6"
                     class="banner-img">
                <div class="carousel-caption d-flex flex-column align-items-start justify-content-center h-100">
                    <h2>KHUYẾN MÃI</h2>
                    <h1 class="display-3 fw-bold">SALE 50%</h1>
                    <p>Mua ngay hôm nay</p>
                </div>
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</div>

<div class="container mt-4">
    @foreach (var kv in Model.OrderBy(x => x.ThuTu))
    {
        var sliderId = $"slider-{kv.Id}";

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold mb-0">@kv.Ten</h2>

            <a asp-controller="Product"
               asp-action="Index"
               asp-route-khuVucId="@kv.Id"
               class="btn btn-outline-primary btn-sm">
                Xem thêm
            </a>
        </div>

        @if (kv.SanPhams != null && kv.SanPhams.Any())
        {
            <div class="product-slider-wrapper mb-5 position-relative">
                <button type="button" class="slider-btn prev" onclick="scrollSlider('@sliderId', -1)">&#10094;</button>
                <button type="button" class="slider-btn next" onclick="scrollSlider('@sliderId', 1)">&#10095;</button>

                <div class="product-slider" id="@sliderId">
                    @foreach (var item in kv.SanPhams)
                    {
                        <div class="product-item">
                            <div class="card h-100 shadow-sm border-0">
                                <a asp-controller="Product"
                                   asp-action="Details"
                                   asp-route-id="@item.MaSanPham"
                                   class="text-decoration-none">
                                    <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                                         class="card-img-top p-2"
                                         alt="@item.TenSanPham"
                                         style="height: 180px; object-fit: contain;">
                                </a>

                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title text-truncate">
                                        <a asp-controller="Product"
                                           asp-action="Details"
                                           asp-route-id="@item.MaSanPham"
                                           class="text-decoration-none text-dark">
                                            @item.TenSanPham
                                        </a>
                                    </h5>

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <p class="card-text text-danger fw-bold fs-5 mb-0">
                                            @item.Gia.ToString("N0") VNĐ
                                        </p>

                                        <span class="badge bg-success">
                                            Đã bán @item.DaBan
                                        </span>
                                    </div>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="btn-group">
                                            <a asp-area="Admin"
                                               asp-controller="Product"
                                               asp-action="Edit"
                                               asp-route-id="@item.MaSanPham"
                                               class="btn btn-sm btn-outline-warning">
                                                Sửa
                                            </a>

                                            <form asp-area="Admin"
                                                  asp-controller="Product"
                                                  asp-action="Delete"
                                                  asp-route-id="@item.MaSanPham"
                                                  method="post"
                                                  onsubmit="return confirm('Xóa sản phẩm?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger">
                                                    Xóa
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <button type="button"
                                                class="btn btn-dark btn-add-to-cart"
                                                data-id="@item.MaSanPham">
                                            Thêm vào giỏ
                                        </button>
                                    }
                                    else
                                    {
                                        <a asp-area="Identity"
                                           asp-page="/Account/Login"
                                           asp-route-returnUrl="@Context.Request.Path"
                                           class="btn btn-outline-dark">
                                            Thêm vào giỏ
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="col-12 text-center py-4">
                <p class="text-muted">Chưa có sản phẩm</p>
            </div>
        }
    }
</div>

<div id="cart-toast" class="cart-toast">
    Đã thêm sản phẩm vào giỏ hàng!
</div>

@section Scripts {
    <script>
        function scrollSlider(id, direction) {
            const slider = document.getElementById(id);
            if (!slider) return;

            const item = slider.querySelector(".product-item");
            if (!item) return;

            const scrollAmount = item.offsetWidth + 20;
            slider.scrollBy({
                left: direction * scrollAmount,
                behavior: "smooth"
            });
        }

        function showCartToast(message, isError = false) {
            const toast = document.getElementById("cart-toast");
            if (!toast) return;

            toast.textContent = message;
            toast.style.background = isError ? "#dc3545" : "#198754";
            toast.classList.add("show");

            setTimeout(() => {
                toast.classList.remove("show");
            }, 2000);
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".btn-add-to-cart").forEach(btn => {
                btn.addEventListener("click", async function () {
                    const id = this.dataset.id;

                    try {
                        const res = await fetch("/Cart/AddToCartAjax", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                                "X-Requested-With": "XMLHttpRequest"
                            },
                            body: `id=${id}&quantity=1`
                        });

                        const result = await res.json();

                        if (result.redirectToLogin) {
                            window.location.href = result.loginUrl;
                            return;
                        }

                        if (result.success) {
                            showCartToast("Đã thêm sản phẩm vào giỏ hàng!");

                            const badge = document.getElementById("cart-badge");
                            if (badge) {
                                badge.textContent = result.cartCount;
                            }

                            const total = document.getElementById("cart-total");
                            if (total) {
                                total.textContent = Number(result.cartTotal).toLocaleString("vi-VN") + "đ";
                            }

                            const itemsContainer = document.getElementById("cart-dropdown-items");
                            if (itemsContainer && result.items) {
                                if (result.items.length > 0) {
                                    let html = `<div style="max-height: 250px; overflow-y: auto;">`;

                                    result.items.forEach(item => {
                                        html += `
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 60px; height: 60px;" class="me-2">
                                                    ${item.hinhAnh ? `<img src="${item.hinhAnh}" alt="${item.tenSanPham}" style="width:100%; height:100%; object-fit:contain;" />` : ``}
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">${item.tenSanPham}</div>
                                                    <div class="text-muted small">SL: ${item.soLuong}</div>
                                                </div>
                                                <div class="text-danger fw-bold">
                                                    ${Number(item.thanhTien).toLocaleString("vi-VN")}đ
                                                </div>
                                            </div>
                                        `;
                                    });

                                    html += `</div>`;
                                    itemsContainer.innerHTML = html;
                                } else {
                                    itemsContainer.innerHTML = `<div class="py-3 text-center text-muted">Giỏ hàng trống</div>`;
                                }
                            }
                        } else {
                            showCartToast("Không thể thêm vào giỏ hàng!", true);
                        }
                    } catch (error) {
                        console.error("AddToCartAjax error:", error);
                        showCartToast("Có lỗi xảy ra khi thêm vào giỏ hàng!", true);
                    }
                });
            });
        });
    </script>
}