@model IEnumerable<BanHang.Models.SanPham>

@{
    ViewData["Title"] = "Trang chủ";

    var sanPhamNoiBat = Model?.Where(x => x.KhuVucHienThi == "NoiBat").ToList() ?? new List<BanHang.Models.SanPham>();
    var sanPhamMoi = Model?.Where(x => x.KhuVucHienThi == "Moi").ToList() ?? new List<BanHang.Models.SanPham>();
    var giaSieuTot = Model?.Where(x => x.KhuVucHienThi == "GiaTot").ToList() ?? new List<BanHang.Models.SanPham>();
}

<div class="container-fluid p-0">
    <div id="homeSlider" class="carousel slide carousel-fade banner-slider" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c" class="w-100" style="height:500px; object-fit:cover;">
                    <div class="position-absolute top-50 start-0 translate-middle-y text-white ps-5">
                        <h2 class="fw-bold">HỆ TỦ QUẦN ÁO CÁNH KÍNH</h2>
                        <h1 class="display-1 fw-bold">ASTRO</h1>
                        <p class="fs-4">Trải Nghiệm Chọn Trang Phục Đẳng Cấp Hơn</p>
                        <a class="btn btn-light btn-lg mt-3">Xem Chi Tiết</a>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <div class="position-relative">
                    <img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0" class="w-100" style="height:500px; object-fit:cover;">
                    <div class="position-absolute top-50 start-0 translate-middle-y text-white ps-5">
                        <h2 class="fw-bold">NỘI THẤT HIỆN ĐẠI</h2>
                        <h1 class="display-1 fw-bold">MODERN</h1>
                        <p class="fs-4">Thiết kế tinh tế cho không gian sống</p>
                        <a class="btn btn-light btn-lg mt-3">Khám phá</a>
                    </div>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</div>

<div class="container mt-4">
    <!-- SẢN PHẨM NỔI BẬT -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">🛒 Sản phẩm nổi bật</h4>

        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin"
               asp-controller="Product"
               asp-action="Create"
               asp-route-khuVuc="NoiBat"
               class="btn btn-primary shadow-sm">
                + Thêm sản phẩm mới
            </a>
        }
    </div>

    <div class="row">
        @if (sanPhamNoiBat.Any())
        {
            @foreach (var item in sanPhamNoiBat)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                             class="card-img-top p-2"
                             alt="@item.TenSanPham"
                             style="height: 150px; object-fit: contain;">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">@item.TenSanPham</h5>
                            <p class="card-text text-danger fw-bold fs-5">@item.Gia.ToString("N0") VNĐ</p>

                            <div class="mt-auto d-grid gap-2">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group">
                                        <a asp-area="Admin"
                                           asp-controller="Product"
                                           asp-action="Edit"
                                           asp-route-id="@item.MaSanPham"
                                           class="btn btn-sm btn-outline-warning">Sửa</a>

                                        <form asp-area="Admin"
                                              asp-controller="Product"
                                              asp-action="Delete"
                                              asp-route-id="@item.MaSanPham"
                                              method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Xóa</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@item.MaSanPham"
                                       class="btn btn-dark">
                                        Thêm vào giỏ
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-4">
                <p class="text-muted">Chưa có sản phẩm nổi bật.</p>
            </div>
        }
    </div>

    <hr class="my-5" />

    <!-- SẢN PHẨM MỚI -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">✨ Sản phẩm mới</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin"
               asp-controller="Product"
               asp-action="Create"
               asp-route-khuVuc="Moi"
               class="btn btn-primary shadow-sm">
                + Thêm sản phẩm mới
            </a>
        }
    </div>

    <div class="row">
        @if (sanPhamMoi.Any())
        {
            @foreach (var item in sanPhamMoi)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                             class="card-img-top p-2"
                             alt="@item.TenSanPham"
                             style="height: 100px; object-fit: contain;">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">@item.TenSanPham</h5>
                            <p class="card-text text-danger fw-bold fs-5">@item.Gia.ToString("N0") VNĐ</p>

                            <div class="mt-auto d-grid gap-2">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group">
                                        <a asp-area="Admin"
                                           asp-controller="Product"
                                           asp-action="Edit"
                                           asp-route-id="@item.MaSanPham"
                                           class="btn btn-sm btn-outline-warning">Sửa</a>

                                        <form asp-area="Admin"
                                              asp-controller="Product"
                                              asp-action="Delete"
                                              asp-route-id="@item.MaSanPham"
                                              method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Xóa</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@item.MaSanPham"
                                       class="btn btn-dark">
                                        Thêm vào giỏ
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-4">
                <p class="text-muted">Chưa có sản phẩm mới.</p>
            </div>
        }
    </div>

    <hr class="my-5" />

    <!-- GIÁ SIÊU TỐT -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">🔥 Giá siêu tốt</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin"
               asp-controller="Product"
               asp-action="Create"
               asp-route-khuVuc="GiaTot"
               class="btn btn-primary shadow-sm">
                + Thêm sản phẩm mới
            </a>
        }
    </div>

    <div class="row">
        @if (giaSieuTot.Any())
        {
            @foreach (var item in giaSieuTot)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/250x180" : item.HinhAnh)"
                             class="card-img-top p-2"
                             alt="@item.TenSanPham"
                             style="height: 200px; object-fit: contain;">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">@item.TenSanPham</h5>
                            <p class="card-text text-danger fw-bold fs-5">@item.Gia.ToString("N0") VNĐ</p>

                            <div class="mt-auto d-grid gap-2">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group">
                                        <a asp-area="Admin"
                                           asp-controller="Product"
                                           asp-action="Edit"
                                           asp-route-id="@item.MaSanPham"
                                           class="btn btn-sm btn-outline-warning">Sửa</a>

                                        <form asp-area="Admin"
                                              asp-controller="Product"
                                              asp-action="Delete"
                                              asp-route-id="@item.MaSanPham"
                                              method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Xóa</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-id="@item.MaSanPham"
                                       class="btn btn-dark">
                                        Thêm vào giỏ
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-4">
                <p class="text-muted">Chưa có sản phẩm giá siêu tốt.</p>
            </div>
        }
    </div>
</div>