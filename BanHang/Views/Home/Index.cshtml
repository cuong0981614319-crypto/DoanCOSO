@section Scripts {
    <script>
        function scrollSlider(id, direction) {                                                                                                                                  
            const slider = document.getElementById(id);
            if (!slider) return;                                                                                                    
            const item = slider.querySelector(".product-item");
            if (!item) return;
            const scrollAmount = item.offsetWidth + 20;
            slider.scrollBy({
                left: direction * scrollAmount,
                behavior: "smooth"
            });
        }

        // Các hàm Toast và Ajax giữ nguyên từ code cũ của ông...
        function showCartToast(message, isError = false) {
            const toast = document.getElementById("cart-toast");
            if (!toast) return;
            toast.textContent = message;                                                                                                                                                                                
            toast.style.background = isError ? "#dc3545" : "#198754";
            toast.classList.add("show");
            setTimeout(() => { toast.classList.remove("show"); }, 2000);
        }

        document.addEventListener("DOMContentLoaded", function () {
            // Logic Add to Cart Ajax giữ nguyên...
        });
    </script>
}