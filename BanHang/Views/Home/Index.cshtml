@model IEnumerable<BanHang.Models.KhuVucHienThi>

@{
    ViewData["Title"] = "Trang chủ";
    var dangLocDanhMuc = ViewBag.MaDanhMucDangChon != null;
    var promoProducts = dangLocDanhMuc
        ? new List<BanHang.Models.SanPham>()
        : (ViewBag.PromoProducts as IEnumerable<BanHang.Models.SanPham> ?? new List<BanHang.Models.SanPham>());
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
@if (!dangLocDanhMuc)
{
    <div class="container-fluid p-0">
        <div id="homeSlider" class="carousel slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c" class="banner-img">
                    <div class="carousel-caption d-flex flex-column align-items-start justify-content-center h-100">
                        <h2>HỆ TỦ QUẦN ÁO CÁNH KÍNH</h2>
                        <h1 class="display-3 fw-bold">ASTRO</h1>
                        <p>Trải Nghiệm Chọn Trang Phục Đẳng Cấp Hơn</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0" class="banner-img">
                    <div class="carousel-caption d-flex flex-column align-items-start justify-content-center h-100">
                        <h2>NỘI THẤT HIỆN ĐẠI</h2>
                        <h1>Hưng Hạnh</h1>
                        <p>Thiết kế tối giản - sang trọng</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6" class="banner-img">
                    <div class="carousel-caption d-flex flex-column align-items-start justify-content-center h-100">
                        <h2>KHUYẾN MÃI</h2>
                        <h1 class="display-3 fw-bold">SALE 40%</h1>
                        <p>Mua ngay hôm nay</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
}
<div class="container mt-5">


    @{
        var bestSellers = (ViewBag.BestSellers as List<BanHang.Models.SanPham>) ?? new List<BanHang.Models.SanPham>();
        var bestSellerSliderId = "slider-best-sellers";
    }
    @if (!dangLocDanhMuc && bestSellers.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold mb-0 text-danger"><i class="bi bi-fire"></i> Sản phẩm bán chạy</h2>
        </div>
            <a asp-controller="Product" asp-action="Index" asp-route-isPromo="true" class="btn btn-outline-primary btn-sm">Xem thêm</a>
        </div>
        <div class="product-slider-wrapper mb-5 position-relative">
            <button type="button" class="slider-btn prev" onclick="scrollSlider('@bestSellerSliderId', -1)">&#10094;</button>
            <button type="button" class="slider-btn next" onclick="scrollSlider('@bestSellerSliderId', 1)">&#10095;</button>

            <div class="product-slider" id="@bestSellerSliderId">
                @foreach (var item in bestSellers)
                {
                    <div class="product-item">
                        <div class="card h-100 shadow-sm border-0">

                            @* PHẢI CÓ CLASS product-img-box Ở ĐÂY *@
                            <div class="product-img-box">
                                @if (item.DaBan < 20)
                                {
                                    <div class="promo-tag-fixed">
                                        -@item.PhanTramGiam%
                                    </div>
                                }

                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham">
                                    <img src="@item.HinhAnh" class="card-img-top p-2"
                                         style="height: 180px; object-fit: contain;">
                                </a>
                            </div>

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title text-truncate">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham" class="text-decoration-none text-dark">
                                        @item.TenSanPham
                                    </a>
                                </h5>

                                <div class="card-body d-flex flex-column">


                                    <div class="price-section">
                                        @if (item.DaBan < 20)
                                        {
                                            @* Hiển thị giá gốc bị gạch ngang *@
                                            <small class="text-muted text-decoration-line-through">
                                                @item.Gia.ToString("N0") VNĐ
                                            </small>
                                            @* Hiển thị giá sau giảm *@
                                            <p class="card-text text-danger fw-bold fs-5 mb-0">
                                                @item.GiaKhuyenMai.ToString("N0") VNĐ
                                            </p>
                                            @* Hiển thị phần trăm giảm *@
                                            <div class="d-flex align-items-center gap-1 mt-1">
                                                <span class="text-warning">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= Math.Round(item.AvgRating))
                                                        {
                                                            <span>★</span>
                                                        }
                                                        else
                                                        {
                                                            <span>☆</span>
                                                        }
                                                    }
                                                </span>
                                                <small class="text-muted">
                                                    (@item.TotalReviews)
                                                </small>
                                            </div>

                                        }
                                        else
                                        {
                                            <p class="card-text text-danger fw-bold fs-5 mb-0">
                                                @item.Gia.ToString("N0") VNĐ
                                            </p>
                                            <div class="d-flex align-items-center gap-1 mt-1">
                                                <span class="text-warning">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= Math.Round(item.AvgRating))
                                                        {
                                                            <span>★</span>
                                                        }
                                                        else
                                                        {
                                                            <span>☆</span>
                                                        }
                                                    }
                                                </span>
                                                <small class="text-muted">
                                                    (@item.TotalReviews)
                                                </small>
                                            </div>
                                        }
                                    </div>

                                    <div class="mt-2 d-flex justify-content-between align-items-center">
                                        <small class="text-muted">Đã bán: @item.DaBan</small>

                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <hr class="my-5" />
    }

