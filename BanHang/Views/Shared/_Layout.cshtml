@using BanHang.Extensions
@using BanHang.Models

@{
    var cart = Context.Session.GetObjectFromJson<List<CartItem>>("CART") ?? new List<CartItem>();
    var cartCount = cart.Sum(x => x.SoLuong);
    var cartTotal = cart.Sum(x => x.ThanhTien);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Nội Thất Nhựa Đài Loan Hưng Hạnh</title>

    <link rel="icon" href="~/img/anh1.png" />

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
   

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/BanHang.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- HEADER -->
    <header class="bg-white border-bottom">

        <div class="container py-3">
            <div class="row align-items-center">

                <!-- LOGO -->
                <div class="col-md-3">
                    <a asp-area=""
                       asp-controller="Home"
                       asp-action="Index"
                       class="text-decoration-none">

                        <img src="/img/anh1.png"
                             alt="Hung Hanh Logo"
                             class="logo-img" />
                    </a>
                </div>

                <!-- SEARCH -->
                <div class="col-md-5">
                    <form method="get"
                          action="/Product/Search"
                          class="search-box">

                        <input type="text"
                               id="searchInput"
                               name="keyword"
                               placeholder="Tìm kiếm sản phẩm..."
                               autocomplete="off" />

                        <button type="submit" id="searchBtn">
                            <i class="fa fa-search"></i>
                        </button>

                        <div id="searchSuggestions"
                             class="search-suggestions">
                        </div>
                    </form>
                </div>

                <!-- RIGHT -->
                <div class="col-md-4 d-flex justify-content-end align-items-center gap-3">

                    <partial name="_LoginPartial" />

                    <!-- CART -->
                    <div class="dropdown">

                        <a asp-controller="Cart"
                           asp-action="Index"
                           class="text-dark text-decoration-none d-flex align-items-center position-relative"
                           id="cartDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">

                            <div class="me-2 position-relative">
                                <i class="bi bi-bag"
                                   style="font-size: 26px;"></i>

                                <span id="cart-badge"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    @cartCount
                                </span>
                            </div>

                            <span class="fw-bold">Giỏ hàng</span>
                        </a>

                        <div class="dropdown-menu dropdown-menu-end p-3 shadow-lg border-0 mt-3"
                             aria-labelledby="cartDropdown">

                            <h6 class="fw-bold mb-3">GIỎ HÀNG</h6>

                            <hr />

                            <div id="cart-dropdown-items">

                                @if (cart.Any())
                                {
                                    <div style="max-height:400px; overflow-y:auto;">

                                        @foreach (var item in cart)
                                        {
                                            <div class="d-flex align-items-center mb-3">

                                                <div style="width:60px; height:60px;"
                                                     class="me-2">

                                                    <img src="@item.HinhAnh"
                                                         alt="@item.TenSanPham"
                                                         style="width:100%; height:100%; object-fit:contain;" />
                                                </div>

                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">
                                                        @item.TenSanPham
                                                    </div>

                                                    <div class="text-muted small">
                                                        SL: @item.SoLuong
                                                    </div>
                                                </div>

                                                <div class="text-danger fw-bold">
                                                    @item.ThanhTien.ToString("N0")đ
                                                </div>
                                            </div>
                                        }

                                    </div>
                                }
                                else
                                {
                                    <div class="text-center text-muted py-3">
                                        Giỏ hàng trống
                                    </div>
                                }

                            </div>

                            <hr />

                            <div class="d-flex justify-content-between mb-3">
                                <span class="fw-semibold">TỔNG TIỀN:</span>

                                <span class="fw-bold text-danger">
                                    @cartTotal.ToString("N0")đ
                                </span>
                            </div>

                            <div class="d-flex gap-2">

                                <a asp-controller="Cart"
                                   asp-action="Index"
                                   class="btn btn-outline-dark flex-grow-1 btn-sm">
                                    XEM GIỎ HÀNG
                                </a>

                                <a asp-controller="Cart"
                                   asp-action="Checkout"
                                   class="btn btn-dark flex-grow-1 btn-sm">
                                    THANH TOÁN
                                </a>
                            </div>

                        </div>
                    </div>

                </div>

            </div>
        </div>

        <!-- MENU -->
        <nav class="navbar navbar-expand-lg py-0 border-top">

            <div class="container justify-content-center">

                <ul class="navbar-nav gap-4 fw-semibold text-uppercase align-items-center"
                    style="font-size:13px;">

                    @await Component.InvokeAsync("Menu")

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                           asp-area=""
                           asp-controller="CongCu"
                           asp-action="Thietke">
                            Thiết kế - Thi công
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                           asp-area=""
                           asp-controller="CongCu"
                           asp-action="Khuyenmai">
                            Khuyến mãi
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                           asp-area=""
                           asp-controller="CongCu"
                           asp-action="Tintuc">
                            Tin tức
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                        asp-area=""
                           asp-controller="CongCu"
                           asp-action="Cuahang">
                            Cửa hàng
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark py-3 fw-bold text-primary"
                               asp-area="Admin"
                               asp-controller="ThongKe"
                               asp-action="Index">
                                <i class="fas fa-user-shield me-1"></i> Trang Quản Trị
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark py-3"
                               asp-controller="DonHang"
                               asp-action="MyOrders">
                                Đơn Hàng Của Tôi
                            </a>
                        </li>
                    }
                </ul>

            </div>

        </nav>

    </header>

    <!-- BODY -->
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-light pt-5 mt-5 border-top">

        <div class="container">

            <div class="row">

                <div class="col-md-3">
                    <h5 class="fw-bold">NỘI THẤT HƯNG HẠNH</h5>

                    <p>
                        Nội thất Hưng Hạnh chuyên cung cấp các sản phẩm
                        nội thất nhựa Đài Loan chất lượng cao.
                    </p>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">THÔNG TIN</h5>

                    <ul class="list-unstyled">
                        <li>Chính Sách Bán Hàng</li>
                        <li>Chính Sách Giao Hàng</li>
                        <li>Chính Sách Bảo Hành</li>
                        <li>Chính Sách Đổi Trả</li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">LIÊN HỆ</h5>

                    <p>📍 Gia Lai</p>
                    <p>📞 0968850604</p>
                    <p>✉ myhanh71298@gmail.com</p>
                </div>

                <div class="col-md-3">

                    <h5 class="fw-bold">Fanpage</h5>

                    <a href="https://www.facebook.com/profile.php?id=100054928830629"
                       target="_blank"
                       class="btn btn-primary mt-2">

                        <i class="bi bi-facebook"></i>
                        Facebook
                    </a>

                </div>

            </div>

        </div>

        <div class="bg-dark text-white text-center p-3 mt-4">
            © @DateTime.Now.Year - BanHang
        </div>

    </footer>

    <!-- FLOATING CONTACT -->
    <div class="floating-contact">

        <a href="tel:0968850604"
           class="floating-btn phone">

            <img src="/img/phone-call.png" />
        </a>

        <a href="#"
           class="floating-btn zalo">

            <img src="/img/Simpleicons-Team-Simple-Zalo.512.png" />
        </a>

        <a href="#"
           class="floating-btn messenger">

            <img src="/img/messenger.png" />
        </a>

    </div>

    <!-- CHAT ICON -->
    <div class="chat-icon" onclick="toggleChat()">
        <i class="fa-solid fa-comments"></i>
    </div>

    <!-- KHUNG CHAT -->
    <div id="chatPopup" class="chat-popup">
        <div class="chat-header">
            Tư vấn Hưng Hạnh
            <button class="btn-close btn-close-white float-end" onclick="toggleChat()" style="font-size:12px; margin-top:4px;"></button>
        </div>
        <div class="chat-body" id="chat-body">
            <div class="msg admin">
                Xin chào! Tôi là trợ lý ảo của Nội Thất Hưng Hạnh. Tôi có thể giúp gì cho bạn?
            </div>
        </div>
        <div class="chat-footer">
            <input type="text" id="chat-input" placeholder="Nhập tin nhắn..." onkeypress="handleChatKeyPress(event)">
            <button onclick="sendChatMessage()"><i class="fa fa-paper-plane"></i></button>
        </div>
    </div>

    <!-- SCRIPT -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        let isTyping = false;

        function toggleChat() {
            const chatPopup = document.getElementById("chatPopup");
            chatPopup.classList.toggle("active");

            // Focus input when opening
            if (chatPopup.classList.contains("active")) {
                setTimeout(() => {
                    document.getElementById("chat-input").focus();
                }, 300);
            }
        }

        function handleChatKeyPress(event) {
            if (event.key === 'Enter') {
                sendChatMessage();
            }
        }

        async function sendChatMessage() {
            const input = document.getElementById("chat-input");
            const message = input.value.trim();
            if (!message || isTyping) return;

            // Thêm tin nhắn của User
            addMessage("user", message);
            input.value = "";
            isTyping = true;

            // Thêm typing indicator
            const chatBody = document.getElementById("chat-body");
            const typingDiv = document.createElement("div");
            typingDiv.className = "msg admin typing";
            typingDiv.id = "typingIndicator";
            typingDiv.innerText = "Đang gõ...";
            chatBody.appendChild(typingDiv);
            chatBody.scrollTop = chatBody.scrollHeight;

            try {
                const response = await fetch('/api/Chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ message: message })
                });

                const data = await response.json();
                
                // Xoá typing
                const indicator = document.getElementById("typingIndicator");
                if (indicator) indicator.remove();

                // Thêm tin nhắn Bot
                addMessage("admin", data.reply);
            } catch (error) {
                const indicator = document.getElementById("typingIndicator");
                if (indicator) indicator.remove();
                addMessage("admin", "Xin lỗi, đã có lỗi xảy ra. Vui lòng thử lại sau.");
            } finally {
                isTyping = false;
            }
        }

        function addMessage(sender, text) {
            const chatBody = document.getElementById("chat-body");
            const msgDiv = document.createElement("div");
            msgDiv.className = "msg " + sender;
            
            // Format line breaks
            text = text.replace(/\n/g, "<br>");
            // Format bold text **text** to <strong>text</strong>
            text = text.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");

            msgDiv.innerHTML = text;
            chatBody.appendChild(msgDiv);
            chatBody.scrollTop = chatBody.scrollHeight;
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>