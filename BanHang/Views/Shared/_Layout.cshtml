@using BanHang.Extensions
@using BanHang.Models

@{
    var cart = Context.Session.GetObjectFromJson<List<CartItem>>("CART") ?? new List<CartItem>();
    var cartCount = cart.Sum(x => x.SoLuong);
    var cartTotal = cart.Sum(x => x.ThanhTien);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Nội Thất Nhựa Đài Loan Hưng hạnh</title>
    <link rel="icon" href="~/img/anh1.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BanHang.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header class="bg-white border-bottom">
        <div class="container py-3">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <a asp-area=""
                       asp-controller="Home"
                       asp-action="Index"
                       class="text-decoration-none">
                        <img src="/img/anh1.png"
                             alt="Hung Hanh Logo"
                             class="logo-img" />
                    </a>
                </div>

                <form method="get" action="/Product/Search" class="search-box">
                    <input type="text"
                           id="searchInput"
                           name="keyword"
                           placeholder="Tìm kiếm sản phẩm..."
                           autocomplete="off" />

                    <button type="submit" id="searchBtn">
                        <i class="fa fa-search"></i>
                    </button>

                    <div id="searchSuggestions" class="search-suggestions"></div>
                </form>

                <div class="col-md-4 d-flex justify-content-end align-items-center gap-3">
                    <partial name="_LoginPartial" />

                    <div class="dropdown">
                        <a asp-controller="Cart"
                           asp-action="Index"
                           class="text-dark text-decoration-none d-flex align-items-center position-relative"
                           id="cartDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            <div class="me-2 position-relative">
                                <i class="bi bi-bag" style="font-size: 26px;"></i>
                                <span id="cart-badge"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      style="font-size: 12px;">
                                    @cartCount
                                </span>
                            </div>
                            <span class="fw-bold">Giỏ hàng</span>
                        </a>

                        <div class="dropdown-menu dropdown-menu-end p-3 shadow-lg border-0 mt-3" aria-labelledby="cartDropdown">
                            <h6 class="fw-bold mb-3">GIỎ HÀNG</h6>
                            <hr />

                            <div id="cart-dropdown-items">
                                @if (cart.Any())
                                {
                                    <div style="max-height: 400px; overflow-y: auto;">
                                        @foreach (var item in cart)
                                        {
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 60px; height: 60px;" class="me-2">
                                                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                                                    {
                                                        <img src="@item.HinhAnh"
                                                             alt="@item.TenSanPham"
                                                             style="width: 100%; height: 100%; object-fit: contain;" />
                                                    }
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">@item.TenSanPham</div>
                                                    <div class="text-muted small">SL: @item.SoLuong</div>
                                                </div>
                                                <div class="text-danger fw-bold">
                                                    @item.ThanhTien.ToString("N0")đ
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="py-3 text-center text-muted">Giỏ hàng trống</div>
                                }
                            </div>

                            <hr />
                            <div class="d-flex justify-content-between mb-3">
                                <span class="fw-semibold">TỔNG TIỀN:</span>
                                <span id="cart-total" class="fw-bold text-danger">@cartTotal.ToString("N0")đ</span>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-controller="Cart"
                                   asp-action="Index"
                                   class="btn btn-outline-dark flex-grow-1 btn-sm fw-bold py-2">
                                    XEM GIỎ HÀNG
                                </a>
                                <a asp-controller="Cart"
                                   asp-action="Checkout"
                                   class="btn btn-dark flex-grow-1 btn-sm fw-bold py-2">
                                    THANH TOÁN
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg py-0 border-top">
            <div class="container justify-content-center">
                <ul class="navbar-nav gap-4 fw-semibold text-uppercase align-items-center" style="font-size: 13px;">
                    @await Component.InvokeAsync("Menu")

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                           asp-area=""
                           asp-controller="CongCu"
                           asp-action="Thietke">
                            Thiết kế - Thi công
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                        asp-area=""
                           asp-controller="CongCu"
                           asp-action="Khuyenmai">
                            Khuyến mãi
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                           asp-area=""
                           asp-controller="CongCu"
                           asp-action="Tintuc">
                            Tin tức
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3"
                           asp-area=""
                           asp-controller="CongCu"
                           asp-action="Cuahang">
                            Cửa hàng
                        </a>
                    </li>
                    

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark py-3"
                               href="#"
                               id="adminDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                <i class="bi bi-gear me-1"></i> Quản lý
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="adminDropdown">
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="Product"
                                       asp-action="Index">
                                        📦 Sản phẩm
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="DanhMuc"
                                       asp-action="Index">
                                        📂 Danh mục
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="KhuVuc"
                                       asp-action="Index">
                                        📍 Khu vực
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="DonHang"
                                       asp-action="Index">
                                        🧾 Đơn hàng
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                    @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a asp-controller="DonHang"
                               asp-action="MyOrders"
                               class="nav-link text-dark py-3">
                                Đơn hàng của tôi
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="bg-light pt-5 mt-5 border-top">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <h5 class="fw-bold">NỘI THẤT HƯNG HẠNH</h5>
                    <p>
                        Nội thất Hưng Hạnh chuyên cung cấp các sản phẩm nội thất
                        nhựa Đài Loan chất lượng cao, thiết kế hiện đại và bền bỉ.
                    </p>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">THÔNG TIN</h5>
                    <ul class="list-unstyled">
                        <li>Chính Sách Bán Hàng</li>
                        <li>Chính Sách Giao Hàng</li>
                        <li>Chính Sách Bảo Hành</li>
                        <li>Chính Sách Đổi Trả</li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">THÔNG TIN LIÊN HỆ</h5>
                    <p>📍 Thôn 1, Xã Bàu Cạn, Tỉnh Gia Lai</p>
                    <p>📞 096 8850604</p>
                    <p>✉ myhanh71298@gmail.com</p>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold mb-3 text-uppercase">Fanpage</h5>

                    <div class="fanpage-box">
                        <img src="/img/anh1.png" alt="Hưng Hạnh" class="fanpage-logo" />

                        <div class="fanpage-content">
                            <div class="fanpage-name">Nội Thất Hưng Hạnh</div>
                            <a href="https://www.facebook.com/profile.php?id=100054928830629"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="fanpage-link">
                                Xem fanpage
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4 pb-3">
                <a href="https://www.facebook.com/share/18b6hrEarR/?mibextid=wwXIfr"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="mx-2 text-decoration-none">
                    <i class="bi bi-facebook"></i> Facebook
                </a>

                <a href="https://youtube.com"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="mx-2 text-decoration-none">
                    <i class="bi bi-youtube"></i> Youtube
                </a>

                <a href="https://instagram.com"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="mx-2 text-decoration-none">
                    <i class="bi bi-instagram"></i> Instagram
                </a>

                <a href="https://www.tiktok.com/@@haihung160797"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="mx-2 text-decoration-none">
                    <i class="bi bi-tiktok"></i> TikTok
                </a>
            </div>
        </div>

        <div class="bg-dark text-white text-center p-3">
            © @DateTime.Now.Year - BanHang
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <div class="floating-contact">
        <a href="tel:0968850604" class="floating-btn phone" title="Gọi ngay">
            <span>
                <img src="/img/phone-call.png"
                     alt="Hung Hanh Logo"
                     class="logo-img" />
            </span>
        </a>

        <a href="https://cdn.hstatic.net/files/200000065946/file/stick_zalo.png" target="_blank" class="floating-btn zalo" title="Chat Zalo">
            <span>
                <img src="/img/Simpleicons-Team-Simple-Zalo.512.png"
                     alt="Hung Hanh Logo"
                     class="logo-img" />
            </span>
        </a>

        <a href="https://m.me/yourpage" target="_blank" class="floating-btn messenger" title="Messenger">
            <span>
                <img src="/img/messenger.png"
                     alt="Hung Hanh Logo"
                     class="logo-img" />
            </span>
        </a>
    </div>
    <script>
            const searchInput = document.getElementById("searchInput");
            const suggestionsBox = document.getElementById("searchSuggestions");

            let debounceTimer;

            searchInput.addEventListener("input", function () {
                const keyword = this.value.trim();

                clearTimeout(debounceTimer);

                if (keyword.length === 0) {
                    suggestionsBox.style.display = "none";
                    suggestionsBox.innerHTML = "";
                    return;
                }

                debounceTimer = setTimeout(() => {
                    fetch(`/Home/SearchSuggestions?keyword=${encodeURIComponent(keyword)}`)
                        .then(response => response.json())
                        .then(data => {
                            if (!data || data.length === 0) {
                                suggestionsBox.innerHTML = `<div class="search-empty">Không tìm thấy sản phẩm</div>`;
                                suggestionsBox.style.display = "block";
                                return;
                            }

                            let html = "";

                                        data.forEach(item => {
                html += `
                    <a href="/Product/Details/${item.id}" class="search-item">
                        <img src="${item.image}" alt="${item.name}">
                        <div class="search-item-info">
                            <div class="search-item-name">${item.name}</div>
                            <div class="search-item-price">
                                ${Number(item.price).toLocaleString('vi-VN')}đ
                            </div>
                        </div>
                    </a>
                `;
            });

                            suggestionsBox.innerHTML = html;
                            suggestionsBox.style.display = "block";
                        })
                        .catch(error => {
                            console.error(error);
                            suggestionsBox.style.display = "none";
                        });
                }, 300);
            });

            document.addEventListener("click", function (e) {
                if (!document.querySelector(".search-box").contains(e.target)) {
                    suggestionsBox.style.display = "none";
                }
            });

            searchInput.addEventListener("focus", function () {
                if (suggestionsBox.innerHTML.trim() !== "") {
                    suggestionsBox.style.display = "block";
                }
            });
    </script>
</body>

</html>