@using BanHang.Extensions
@using BanHang.Models

@{
    var cart = Context.Session.GetObjectFromJson<List<CartItem>>("CART") ?? new List<CartItem>();
    var cartCount = cart.Sum(x => x.SoLuong);
    var cartTotal = cart.Sum(x => x.ThanhTien);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BanHang</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BanHang.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header class="bg-white border-bottom">
        <div class="container py-3">
            <div class="row align-items-center">
                <div class="col-md-3">
                    <a asp-area=""
                           asp-controller="Home"
                           asp-action="Index"
                           class="text-decoration-none">
                        <img src="/img/anh1.png"
                             alt="Hung Hanh Logo"
                             style="height: 80px; width: auto; object-fit: contain;" />
                    </a>
                </div>

                <div class="col-md-5">
                    <form asp-controller="Product" asp-action="Search" method="get" class="d-flex">
                        <input type="text" name="keyword" value="@Context.Request.Query["keyword"]" class="form-control" placeholder="Tìm kiếm sản phẩm..." />
                        <button type="submit" class="btn btn-dark ms-2">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                </div>

                <div class="col-md-4 d-flex justify-content-end align-items-center gap-3">
                    <partial name="_LoginPartial" />

                  
                    <div class="dropdown">
                        <a asp-controller="Cart"
                               asp-action="Index"
                               class="text-dark text-decoration-none d-flex align-items-center position-relative"
                               id="cartDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                            <div class="me-2 position-relative">
                                <i class="bi bi-bag" style="font-size: 26px;"></i>
                                <span id="cart-badge"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      style="font-size: 12px;">
                                    @cartCount
                                </span>
                            </div>
                            <span class="fw-bold" style="font-size: 24px;">Giỏ hàng</span>
                        </a>

                        <div class="dropdown-menu dropdown-menu-end p-3 shadow-lg border-0 mt-3" style="width: 360px;" aria-labelledby="cartDropdown">
                            <h6 class="fw-bold mb-3">GIỎ HÀNG</h6>
                            <hr />

                            <div id="cart-dropdown-items">
                                @if (cart.Any())
                                {
                                    <div style="max-height: 250px; overflow-y: auto;">
                                        @foreach (var item in cart)
                                        {
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 60px; height: 60px;" class="me-2">
                                                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                                                    {
                                                        <img src="@item.HinhAnh"
                                                             alt="@item.TenSanPham"
                                                             style="width: 100%; height: 100%; object-fit: contain;" />
                                                    }
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold">@item.TenSanPham</div>
                                                    <div class="text-muted small">SL: @item.SoLuong</div>
                                                </div>
                                                <div class="text-danger fw-bold">
                                                    @item.ThanhTien.ToString("N0")đ
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="py-3 text-center text-muted">Giỏ hàng trống</div>
                                }
                            </div>

                            <hr />
                            <div class="d-flex justify-content-between mb-3">
                                <span class="fw-semibold">TỔNG TIỀN:</span>
                                <span id="cart-total" class="fw-bold text-danger">@cartTotal.ToString("N0")đ</span>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-controller="Cart"
                                       asp-action="Index"
                                       class="btn btn-outline-dark flex-grow-1 btn-sm fw-bold py-2">
                                    XEM GIỎ HÀNG
                                </a>
                                <a asp-controller="Cart"
                                       asp-action="Checkout"
                                       class="btn btn-dark flex-grow-1 btn-sm fw-bold py-2">
                                    THANH TOÁN
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg py-0 border-top">
            <div class="container justify-content-center">
                <ul class="navbar-nav gap-4 fw-semibold text-uppercase align-items-center" style="font-size: 13px;">
                    @await Component.InvokeAsync("Menu")

                    <li class="nav-item">
                        <a class="nav-link text-dark py-3" href="#">Thiết kế - Thi công</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark py-3" href="#">Khuyến mãi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark py-3" href="#">Tin tức</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark py-3" href="#">Về MOHO</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark py-3" href="#">Cửa hàng</a>
                    </li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark py-3"
                                   href="#"
                                   id="adminDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                <i class="bi bi-gear me-1"></i> Quản lý
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="adminDropdown">
                                <li>
                                    <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="Product"
                                           asp-action="Index">
                                        📦 Sản phẩm
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="DanhMuc"
                                           asp-action="Index">
                                        📂 Danh mục
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="KhuVuc"
                                           asp-action="Index">
                                        📍 Khu vực
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="DonHang"
                                           asp-action="Index">
                                        🧾 Đơn hàng
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                    @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a asp-controller="DonHang"
                                   asp-action="MyOrders"
                                   class="nav-link text-dark py-3">
                                Đơn hàng của tôi
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="bg-light pt-5 mt-5 border-top">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <h5 class="fw-bold">NỘI THẤT HƯNG HẠNH</h5>
                    <p>
                        Nội thất Hưng Hạnh chuyên cung cấp các sản phẩm nội thất
                        nhựa Đài Loan chất lượng cao, thiết kế hiện đại và bền bỉ.
                    </p>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">THÔNG TIN</h5>
                    <ul class="list-unstyled">
                        <li>Chính Sách Bán Hàng</li>
                        <li>Chính Sách Giao Hàng</li>
                        <li>Chính Sách Bảo Hành</li>
                        <li>Chính Sách Đổi Trả</li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">THÔNG TIN LIÊN HỆ</h5>
                    <p>📍 162 HT17, P. Hiệp Thành, Q12, TP.HCM</p>
                    <p>📞 0971 114 140</p>
                    <p>✉ hunganh@gmail.com</p>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold">FANPAGE</h5>
                    <img src="/images/1.png" style="width:120px;" />
                </div>
            </div>

            <div class="text-center mt-4 pb-3">
                <span class="mx-2">Facebook</span>
                <span class="mx-2">Youtube</span>
                <span class="mx-2">Instagram</span>
                <span class="mx-2">TikTok</span>
            </div>
        </div>

        <div class="bg-dark text-white text-center p-3">
            © @DateTime.Now.Year - BanHang
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>