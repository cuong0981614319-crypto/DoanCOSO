@model IEnumerable<BanHang.Models.DanhMuc>

<li class="nav-item dropdown custom-nav-dropdown">
    <a class="nav-link dropdown-toggle text-dark py-3 fw-semibold" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        SẢN PHẨM
    </a>
    <ul class="dropdown-menu shadow-sm border-0 animated-fade-in" aria-labelledby="navbarDropdown">
        <li><a class="dropdown-item py-2" asp-area="" asp-controller="Product" asp-action="Index">Tất cả sản phẩm</a></li>
        <li><hr class="dropdown-divider"></li>
        
        @foreach (var item in Model)
        {
            <li>
                <a class="dropdown-item py-2" asp-area="" asp-controller="Product"
                       asp-action="Category" asp-route-id="@item.MaDanhMuc">
                    @item.TenDanhMuc
                </a>
            </li>
        }
    </ul>
</li>