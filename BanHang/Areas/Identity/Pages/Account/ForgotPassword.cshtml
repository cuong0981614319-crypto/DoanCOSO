@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "QUÊN MẬT KHẨU";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login_logout.css" asp-append-version="true" />
}

<div class="login-wrapper">
    <div class="login-box">
        <div class="login-header text-center">
            <h2 class="fw-bold">@ViewData["Title"]</h2>
            <p class="text-muted">Nhập email của bạn để nhận mã khôi phục mật khẩu OTP.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 small" role="alert"></div>
            <div class="mb-3">
                <input asp-for="Input.Email" class="form-control custom-input" autocomplete="username" aria-required="true" placeholder="Nhập Email của bạn" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn-submit-dark w-100 mb-3">GỬI MÃ OTP</button>
        </form>

        <div class="login-footer mt-4 text-center">
            <p><a asp-page="./Login" class="fw-bold text-dark text-decoration-none">← Quay lại Đăng nhập</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}