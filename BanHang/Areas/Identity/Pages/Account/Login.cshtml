@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập tài khoản";
}

<link rel="stylesheet" href="~/css/login_logout.css" asp-append-version="true" />

<div class="login-wrapper">
    <div class="login-box">
        <div class="login-header text-center">
            <h2 class="fw-bold">@ViewData["Title"]</h2>
            <p class="text-muted">Nhập email và mật khẩu của bạn:</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

            @* Khung điền Email *@
            <div class="mb-3">
                <input asp-for="Input.Email" class="form-control custom-input" placeholder="Nhập email hoặc số điện thoại" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            @* Khung điền Mật khẩu *@
            <div class="mb-3">
                <input asp-for="Input.Password" class="form-control custom-input" type="password" placeholder="Mật khẩu" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <p class="recaptcha-notice">
                Website được bảo vệ bởi reCAPTCHA và
                <a href="#">Chính sách bảo mật</a> và
                <a href="#">Điều khoản dịch vụ</a> của Google.
            </p>

            <button id="login-submit" type="submit" class="btn-submit-dark">ĐĂNG NHẬP</button>

            <div class="login-footer mt-4">
                <p>Khách hàng mới? <a asp-page="./Register">Tạo tài khoản</a></p>
                <p>Quên mật khẩu? <a id="forgot-password" asp-page="./ForgotPassword">Khôi phục mật khẩu</a></p>
            </div>
        </form>
    </div>
</div>