@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Xác nhận đổi mật khẩu";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Forgot.css" asp-append-version="true" />
}

<div class="confirmation-wrapper">
    <div class="confirmation-container">
        <h2>@ViewData["Title"]</h2>
        <hr />
        <p>
            Mật khẩu của bạn đã được đổi thành: <strong>123456</strong>
        </p>
        <div class="text-center mt-4">
            <a href="/Identity/Account/Login" class="btn-primary" style="text-decoration: none; display: block;">Đăng nhập ngay</a>
        </div>
    </div>
</div>