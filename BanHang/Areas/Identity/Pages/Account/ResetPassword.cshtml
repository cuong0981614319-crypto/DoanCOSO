@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "ĐẶT LẠI MẬT KHẨU";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login_logout.css" asp-append-version="true" />
}

<div class="login-wrapper">
    <div class="login-box">
        <div class="login-header text-center">
            <h2 class="fw-bold">@ViewData["Title"]</h2>
            <p class="text-muted">Nhập mã OTP đã nhận và thông tin mật khẩu mới.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2 small" role="alert"></div>
            <div class="mb-3">
                <input asp-for="Input.Email" class="form-control custom-input" autocomplete="username" aria-required="true" placeholder="Email" readonly />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <input asp-for="Input.Code" class="form-control custom-input" autocomplete="off" aria-required="true" placeholder="Mã OTP 6 số" />
                <span asp-validation-for="Input.Code" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <input asp-for="Input.Password" class="form-control custom-input" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu mới" type="password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control custom-input" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu mới" type="password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn-submit-dark w-100 mb-3">ĐẶT LẠI MẬT KHẨU</button>
        </form>

        <div class="login-footer mt-4 text-center">
            <p><a asp-page="./Login" class="fw-bold text-dark text-decoration-none">← Quay lại Đăng nhập</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
