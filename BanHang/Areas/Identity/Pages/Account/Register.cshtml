@page
@model RegisterModel
@{
    ViewData["Title"] = "Tạo tài khoản";
}

<link rel="stylesheet" href="~/css/login_logout.css" asp-append-version="true" />

<div class="container py-5">
    <div class="row align-items-start">
        <div class="col-md-5 pe-md-5">
            <div class="register-intro">
                <h1 class="fw-bold display-5 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted fs-5">
                    Đăng ký tài khoản chỉ trong 1 phút để tích lũy điểm và nhận ưu đãi từ Hưng Hạnh.
                </p>
                <div class="title-underline"></div>
            </div>
        </div>

        <div class="col-md-7 ps-md-5 border-start">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="register-form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <input asp-for="Input.Email" class="form-control custom-reg-input" placeholder="Email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <input asp-for="Input.Password" class="form-control custom-reg-input" placeholder="Mật khẩu" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control custom-reg-input" placeholder="Xác nhận mật khẩu" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <p class="recaptcha-text mb-4">
                    Website được bảo vệ bởi reCAPTCHA và
                    <a href="#">Chính sách bảo mật</a> và
                    <a href="#">Điều khoản dịch vụ</a> của Google.
                </p>

                <button id="registerSubmit" type="submit" class="btn btn-dark btn-register w-100 mb-3">
                    ĐĂNG KÝ
                </button>
            </form>

            <div class="social-login-area mt-3">

                <div class="divider">
                    <span>HOẶC ĐĂNG KÝ VỚI</span>
                </div>

                <form asp-page-handler="ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div class="d-flex gap-2 mb-4">
                        <button type="submit" name="provider" value="Google" class="btn-social btn-google w-100">
                            <i class="fab fa-google"></i> Google
                        </button>
                        <button type="submit" name="provider" value="Facebook" class="btn-social btn-facebook w-100">
                            <i class="fab fa-facebook-f"></i> Facebook
                        </button>
                    </div>
                </form>

                <a asp-area="" asp-controller="Home" asp-action="Index" class="text-dark small text-decoration-none d-block">
                    ← Quay lại trang chủ
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}