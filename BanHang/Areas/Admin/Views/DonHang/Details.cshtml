@model BanHang.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0 fw-bold">Chi tiết đơn hàng #@Model.MaDonHang</h2>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @* Thông báo thành công/lỗi *@
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @* CỘT TRÁI: THÔNG TIN VÀ CẬP NHẬT *@
        <div class="col-md-5">
            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary">Thông tin chung</h5>
                </div>
                <div class="card-body">
                    <p><strong>Khách hàng:</strong> @Model.HoTen</p>
                    <p><strong>Số điện thoại:</strong> @Model.SoDienThoai</p>
                    <p><strong>Địa chỉ:</strong> @Model.DiaChi</p>
                    <p><strong>Ngày đặt:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold fs-5">@Model.TongTien.ToString("N0") VNĐ</span></p>
                    <p><strong>Trạng thái:</strong> <span class="badge bg-info text-dark">@Model.TrangThai</span></p>
                    <p><strong>Ghi Chú: </strong> @Model.GhiChu</p>
                    <hr />

                    @* Form cập nhật trạng thái *@
                    <form asp-action="UpdateStatus" method="post" class="bg-light p-3 rounded shadow-sm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="maDonHang" value="@Model.MaDonHang" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Thay đổi trạng thái đơn hàng</label>
                            <select name="trangThai" class="form-select border-primary" asp-items="ViewBag.TrangThaiList"></select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold">
                            <i class="bi bi-save me-1"></i> Lưu thay đổi
                        </button>
                    </form>
                </div>
            </div>

            @* PHẦN MỚI: LỊCH SỬ TRẠNG THÁI *@
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-success"><i class="bi bi-clock-history"></i> Nhật ký xử lý</h5>
                </div>
                <div class="card-body">
                    <div class="admin-timeline">
                        @if (Model.LichSuDonHangs != null && Model.LichSuDonHangs.Any())
                        {
                            @foreach (var ls in Model.LichSuDonHangs.OrderByDescending(x => x.NgayTao))
                            {
                                <div class="timeline-item pb-3 border-start border-2 border-light ps-3 position-relative">
                                    <div class="dot bg-success position-absolute rounded-circle" style="width:10px; height:10px; left:-6px; top:5px;"></div>
                                    <div class="fw-bold small text-dark text-uppercase">@ls.TrangThaiMoi</div>
                                    <div class="text-muted" style="font-size: 0.8rem;">@ls.GhiChu</div>
                                    <div class="text-muted small italic">@ls.NgayTao.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted small">Chưa có nhật ký thay đổi.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* CỘT PHẢI: DANH SÁCH SẢN PHẨM *@
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-primary">Sản phẩm trong đơn</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small">
                                <tr>
                                    <th class="ps-3">Sản phẩm</th>
                                    <th>Ảnh</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end pe-3">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ChiTietDonHangs)
                                {
                                    <tr>
                                        <td class="ps-3"><strong>@item.SanPham?.TenSanPham</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.SanPham?.HinhAnh))
                                            {
                                                <img src="@item.SanPham.HinhAnh" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;" />
                                            }
                                        </td>
                                        <td class="text-center">@item.SoLuong</td>
                                        <td class="text-end">@item.DonGia.ToString("N0")</td>
                                        <td class="text-end pe-3 text-danger fw-bold">@((item.SoLuong * item.DonGia).ToString("N0"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-timeline .timeline-item:last-child {
        border-start-color: transparent !important;
    }

    .card {
        border-radius: 10px;
    }

    .btn {
        border-radius: 8px;
    }
</style>