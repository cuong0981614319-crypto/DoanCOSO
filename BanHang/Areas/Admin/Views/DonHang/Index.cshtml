@model IEnumerable<BanHang.Models.DonHang>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Quản lý đơn hàng</h2>

        <a asp-area=""
               asp-controller="Home"
               asp-action="Index"
               class="btn btn-secondary">
            Về trang chủ
        </a>
    </div>
    @{
    var current = ViewBag.CurrentStatus as string;
}

<div class="mb-3">
    <a asp-action="Index" class="btn @(string.IsNullOrEmpty(current) ? "btn-dark" : "btn-outline-dark")">
        Tất cả
    </a>
        <a asp-action="Index" asp-route-status="Đã Thanh Toán"
           class="btn @(current == "Đã Thanh Toán" ? "btn-success" : "btn-outline-success")">
            Đã Thanh Toán
        </a>
        <a asp-action="Index" asp-route-status="Chờ thanh toán"
               class="btn @(current == "Chờ thanh toán" ? "btn-success" : "btn-outline-success")">
            Chờ thanh toán
        </a>
    <a asp-action="Index" asp-route-status="Chờ xác nhận"
       class="btn @(current == "Chờ xác nhận" ? "btn-warning" : "btn-outline-warning")">
        Chờ xác nhận
    </a>

    <a asp-action="Index" asp-route-status="Đang giao"
       class="btn @(current == "Đang giao" ? "btn-info" : "btn-outline-info")">
        Đang giao
    </a>

    <a asp-action="Index" asp-route-status="Hoàn thành"
       class="btn @(current == "Hoàn thành" ? "btn-success" : "btn-outline-success")">
        Hoàn thành
    </a>

    <a asp-action="Index" asp-route-status="Đã hủy"
       class="btn @(current == "Đã hủy" ? "btn-danger" : "btn-outline-danger")">
        Đã hủy
    </a>
</div>
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>SĐT</th>
                            <th>Địa chỉ</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th>Ghi Chú</th>

                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.MaDonHang</td>
                                    <td>@item.HoTen</td>
                                    <td>@item.SoDienThoai</td>
                                    <td>@item.DiaChi</td>
                                    <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-danger fw-bold">@item.TongTien.ToString("N0") VNĐ</td>
                                    <td>
                                        @if (item.DaThanhToan)
                                        {
                                            <span class="badge bg-success">Đã thanh toán</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                                        }
                                    </td>
                                    <td>@item.TrangThai</td>
                                    <td>@item.GhiChu</td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Details"
                                                   asp-route-id="@item.MaDonHang"
                                                   class="btn btn-sm btn-outline-primary">
                                                Chi tiết
                                            </a>

                                            <form asp-action="Delete"
                                                  asp-route-id="@item.MaDonHang"
                                                  method="post"
                                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    Xóa
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    Chưa có đơn hàng nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>