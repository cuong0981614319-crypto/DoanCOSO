@model BanHang.Models.ThongKeDoanhThuViewModel

@{
    ViewData["Title"] = "Thống kê doanh thu";
}

<div class="container mt-4">
    <h2 class="mb-4">Thống kê doanh thu</h2>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6>Doanh thu hôm nay</h6>
                    <h4 class="text-success">@Model.DoanhThuHomNay.ToString("N0") VNĐ</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6>Doanh thu tháng này</h6>
                    <h4 class="text-primary">@Model.DoanhThuThangNay.ToString("N0") VNĐ</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6>Tổng doanh thu</h6>
                    <h4 class="text-danger">@Model.TongDoanhThu.ToString("N0") VNĐ</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6>Số đơn đã thanh toán</h6>
                    <h4>@Model.SoDonDaThanhToan</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" asp-controller="ThongKe" asp-action="Index" class="row g-3">
                <div class="col-md-4">
                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" />
                </div>
                <div class="col-md-4">
                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary">Lọc dữ liệu</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h4 class="mb-0">Biểu đồ tăng trưởng doanh thu</h4>
        </div>
        <div class="card-body">
            <canvas id="revenueChart" style="min-height: 300px; max-height: 400px; width: 100%;"></canvas>
        </div>
    </div>

    <h4 class="mb-3">Chi tiết doanh thu theo ngày</h4>
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Ngày</th>
                <th>Doanh thu</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.DoanhThuTheoNgay)
            {
                <tr>
                    <td>@item.Ngay.ToString("dd/MM/yyyy")</td>
                    <td>@item.DoanhThu.ToString("N0") VNĐ</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('revenueChart').getContext('2d');

            // 1. Nhận mảng dữ liệu từ Model
            const rawLabels = @Html.Raw(Json.Serialize(Model.DoanhThuTheoNgay.Select(x => x.Ngay.ToString("dd/MM"))));
            const rawData = @Html.Raw(Json.Serialize(Model.DoanhThuTheoNgay.Select(x => x.DoanhThu)));

            // 2. Gọi hàm .reverse() để đảo ngược mảng riêng cho biểu đồ (Đảm bảo trục X chạy từ cũ đến mới)
            const labels = rawLabels.reverse();
            const data = rawData.reverse();

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: data,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 5,
                        pointBackgroundColor: '#0d6efd'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString() + ' đ';
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        }
                    }
                }
            });
        });
    </script>
}