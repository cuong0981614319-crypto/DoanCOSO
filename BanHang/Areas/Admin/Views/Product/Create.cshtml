@model BanHang.Models.SanPham
@using Microsoft.EntityFrameworkCore
@using BanHang.Models
@inject ApplicationDbContext _context

@{
    ViewData["Title"] = "Thêm sản phẩm mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Thêm sản phẩm mới</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="KhuVucHienThi" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Khu vực hiển thị</label>
                            <input class="form-control" value="@Model.KhuVucHienThi" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="TenSanPham" class="form-label fw-bold">Tên sản phẩm</label>
                            <input asp-for="TenSanPham" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="TenSanPham" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gia" class="form-label fw-bold">Giá bán (VNĐ)</label>
                                <input asp-for="Gia" type="number" class="form-control" />
                                <span asp-validation-for="Gia" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuong" class="form-label fw-bold">Số lượng trong kho</label>
                                <input asp-for="SoLuong" type="number" class="form-control" />
                                <span asp-validation-for="SoLuong" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh mục sản phẩm</label>
                            <select asp-for="MaDanhMuc" class="form-select">
                                <option value="">-- Chọn một danh mục --</option>

                                @{
                                    var danhMucs = await _context.DanhMucs.ToListAsync();
                                }

                                @foreach (var item in danhMucs)
                                {
                                    <option value="@item.MaDanhMuc">@item.TenDanhMuc</option>
                                }
                            </select>
                            <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label fw-bold">Mô tả chi tiết</label>
                            <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageFile" class="form-label fw-bold">Hình ảnh sản phẩm</label>
                            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                            <small class="text-muted">Nên chọn ảnh định dạng .jpg, .png</small>
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>

                        <hr />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-save"></i> Lưu sản phẩm
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">
                                Quay lại Home
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}