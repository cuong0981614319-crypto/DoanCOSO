@model BanHang.Models.SanPham

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="mb-4">Chỉnh sửa sản phẩm</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="MaSanPham" />
                <input type="hidden" asp-for="HinhAnh" />
                <input type="hidden" asp-for="KhuVucHienThi" />

                <div class="mb-3">
                    <label class="form-label">Khu vực hiển thị</label>
                    <input type="text" class="form-control" value="@Model.KhuVucHienThi" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="TenSanPham" class="form-label">Tên sản phẩm</label>
                    <input asp-for="TenSanPham" class="form-control" />
                    <span asp-validation-for="TenSanPham" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Gia" class="form-label">Giá bán</label>
                    <input asp-for="Gia" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Gia" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SoLuong" class="form-label">Số lượng</label>
                    <input asp-for="SoLuong" type="number" class="form-control" />
                    <span asp-validation-for="SoLuong" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MaDanhMuc" class="form-label">Danh mục</label>
                    <select asp-for="MaDanhMuc" asp-items="ViewBag.MaDanhMuc" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MoTa" class="form-label">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="MoTa" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    <div class="mb-3">
                        <label class="form-label">Ảnh hiện tại</label><br />
                        <img src="@Model.HinhAnh" alt="@Model.TenSanPham"
                             style="max-width: 180px; max-height: 180px; object-fit: contain;"
                             class="border rounded p-2" />
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="ImageFile" class="form-label">Chọn ảnh mới</label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Cập nhật thay đổi</button>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                        Quay lại Home
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}