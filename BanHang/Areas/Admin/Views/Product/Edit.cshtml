@model BanHang.Models.SanPham

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Chỉnh sửa sản phẩm</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="MaSanPham" />
                        <input type="hidden" asp-for="HinhAnh" />

                        <div class="mb-3">
                            <label asp-for="TenSanPham" class="form-label fw-bold"></label>
                            <input asp-for="TenSanPham" class="form-control" />
                            <span asp-validation-for="TenSanPham" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gia" class="form-label fw-bold"></label>
                                <input asp-for="Gia" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="Gia" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="SoLuong" class="form-label fw-bold"></label>
                                <input asp-for="SoLuong" type="number" class="form-control" />
                                <span asp-validation-for="SoLuong" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaDanhMuc" class="form-label fw-bold">Danh mục sản phẩm</label>
                            <select asp-for="MaDanhMuc" asp-items="ViewBag.MaDanhMuc" class="form-select">
                                <option value="">-- Chọn một danh mục --</option>
                            </select>
                            <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label fw-bold"></label>
                            <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.HinhAnh))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Ảnh hiện tại</label>
                                <div>
                                    <img src="@Model.HinhAnh" alt="@Model.TenSanPham" style="max-height: 180px; object-fit: contain;" class="border rounded p-2" />
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="ImageFile" class="form-label fw-bold">Đổi hình ảnh</label>
                            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Cập nhật thay đổi</button>
                            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
