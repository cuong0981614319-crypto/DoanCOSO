@model BanHang.Models.SanPham

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="container mt-4">
    <h2 class="mb-4">Chỉnh sửa sản phẩm</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit"
                  asp-route-id="@Model.MaSanPham"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden" asp-for="MaSanPham" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="KhuVucHienThiId" class="form-label fw-bold">Khu vực hiển thị</label>
                    <select asp-for="KhuVucHienThiId" class="form-select" asp-items="ViewBag.KhuVucHienThiId">
                        <option value="">-- Chọn khu vực --</option>
                    </select>
                    <span asp-validation-for="KhuVucHienThiId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TenSanPham" class="form-label fw-bold">Tên sản phẩm</label>
                    <input asp-for="TenSanPham" class="form-control" />
                    <span asp-validation-for="TenSanPham" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Gia" class="form-label fw-bold">Giá</label>
                    <input asp-for="Gia" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Gia" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="chatlieu" class="form-label fw-bold">Vật liệu</label>
                    <input asp-for="chatlieu" class="form-control" placeholder="Ví dụ: Gỗ sồi, Sắt sơn tĩnh điện..." />
                    <span asp-validation-for="chatlieu" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="kichthuc" class="form-label fw-bold">Kích thước</label>
                    <input asp-for="kichthuc" class="form-control" placeholder="Ví dụ: 120x60x75 cm..." />
                    <span asp-validation-for="kichthuc" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NgayThem" class="form-label fw-bold"></label>

                    <input asp-for="NgayThem"
                           type="date"
                           class="form-control"
                           value="@(Model.NgayThem?.ToString("yyyy-MM-dd"))" />

                    <span asp-validation-for="NgayThem" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MauSac" class="form-label fw-bold">Màu sắc</label>
                    <select asp-for="MauSac" class="form-select">
                        <option value="">-- Chọn màu sắc --</option>
                        <option value="Đen">Đen</option>
                        <option value="Trắng">Trắng</option>
                        <option value="Xám">Xám</option>
                        <option value="Nâu">Nâu</option>
                        <option value="Be">Be</option>
                        <option value="Xanh">Xanh</option>
                        <option value="Đỏ">Đỏ</option>
                    </select>
                    <span asp-validation-for="MauSac" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MaDanhMuc" class="form-label fw-bold">Danh mục</label>
                    <select asp-for="MaDanhMuc" class="form-select" asp-items="ViewBag.MaDanhMuc">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MoTa" class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="MoTa" class="text-danger"></span>
                </div>

                @if (Model.HinhAnhSanPhams != null && Model.HinhAnhSanPhams.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh hiện tại</label>

                        <div class="row">
                            @foreach (var img in Model.HinhAnhSanPhams)
                            {
                                <div class="col-md-3 mb-3">
                                    <div class="border p-2 rounded h-100 bg-white">
                                        <img src="@img.DuongDanAnh"
                                             class="img-fluid"
                                             style="width:100%; height:150px; object-fit:contain;" />

                                        <div class="form-check mt-2">
                                            <input class="form-check-input"
                                                   type="radio"
                                                   name="SelectedThumbnail"
                                                   value="@img.DuongDanAnh"
                                                   @(Model.HinhAnh == img.DuongDanAnh ? "checked" : "") />
                                            <label class="form-check-label">Ảnh đại diện</label>
                                        </div>

                                        <div class="form-check mt-2">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   name="DeletedImageIds"
                                                   value="@img.Id" />
                                            <label class="form-check-label text-danger">Xóa ảnh</label>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="ImageFiles" class="form-label fw-bold">Thêm ảnh mới</label>
                    <input asp-for="ImageFiles"
                           type="file"
                           class="form-control"
                           accept="image/*"
                           multiple
                           id="newImageInput" />
                    <span asp-validation-for="ImageFiles" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Xem trước ảnh mới</label>
                    <div id="newPreviewContainer" class="row g-3"></div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const newImageInput = document.getElementById('newImageInput');
        const newPreviewContainer = document.getElementById('newPreviewContainer');

        if (newImageInput) {
            newImageInput.addEventListener('change', function () {
                newPreviewContainer.innerHTML = '';

                const files = this.files;
                if (!files || files.length === 0) return;

                Array.from(files).forEach((file) => {
                    if (!file.type.startsWith('image/')) return;

                    const reader = new FileReader();

                    reader.onload = function (e) {
                        const col = document.createElement('div');
                        col.className = 'col-md-3 col-6';

                        col.innerHTML = `
                            <div class="border rounded p-2 h-100 text-center bg-white">
                                <img src="${e.target.result}"
                                     class="img-fluid"
                                     style="width:100%; height:150px; object-fit:contain;" />
                            </div>
                        `;

                        newPreviewContainer.appendChild(col);
                    };

                    reader.readAsDataURL(file);
                });
            });
        }
    </script>
}